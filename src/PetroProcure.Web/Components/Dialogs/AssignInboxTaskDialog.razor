<MudDialog>
    <DialogContent>
        <MudSelect T="Guid?" @bind-Value="_userId" Label="کاربر مسئول" Required="true"
                   RequiredError="انتخاب کاربر الزامی است." Variant="Variant.Outlined">
            @foreach (var user in Users)
            {
                <MudSelectItem T="Guid?" Value="@user.Id">@(user.DisplayName ?? user.UserName)</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">انصراف</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_userId.HasValue)" OnClick="Confirm">اختصاص کار</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public IReadOnlyList<UserDto> Users { get; set; } = [];
    private Guid? _userId;
    private void Confirm()=>Dialog.Close(DialogResult.Ok(_userId!.Value));
    private void Cancel()=>Dialog.Cancel();
}
