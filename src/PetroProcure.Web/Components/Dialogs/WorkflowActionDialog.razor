<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">اقدام «@Action.Title» اجرا شود؟</MudText>
        <MudTextField @bind-Value="_comment" Label="توضیحات" Lines="3" Class="mt-3"
                      Required="@Action.RequiresComment" RequiredError="ثبت توضیحات برای این اقدام الزامی است." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">انصراف</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(Action.RequiresComment&&string.IsNullOrWhiteSpace(_comment))" OnClick="Confirm">اجرای اقدام</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; }=default!;
    [Parameter,EditorRequired] public WorkflowActionDto Action { get; set; }=default!;
    private string? _comment;
    private void Confirm()=>Dialog.Close(DialogResult.Ok(_comment?.Trim()));
    private void Cancel()=>Dialog.Cancel();
}
