<MudGrid Spacing="3">
    @foreach (var metric in Metrics)
    {
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="metric-card" Elevation="0">
                <div class="metric-icon"><MudIcon Icon="@metric.Icon" /></div>
                <div><MudText Typo="Typo.caption">@metric.Label</MudText><MudText Typo="Typo.h4">@metric.Value</MudText><MudText Typo="Typo.caption" Color="Color.Success">@metric.Trend</MudText></div>
            </MudPaper>
        </MudItem>
    }
    <MudItem xs="12" lg="8">
        <MudPaper Class="dashboard-panel" Elevation="0">
            <div class="panel-heading"><div><MudText Typo="Typo.h6">فعالیت‌های اخیر</MudText><MudText Typo="Typo.caption">آخرین تغییرات در @Department</MudText></div><MudButton Variant="Variant.Text">مشاهده همه</MudButton></div>
            <MudTable Items="Activities" Dense="true" Hover="true" Elevation="0">
                <HeaderContent><MudTh>شماره پرونده</MudTh><MudTh>عنوان</MudTh><MudTh>وضعیت</MudTh><MudTh>آخرین تغییر</MudTh></HeaderContent>
                <RowTemplate><MudTd DataLabel="شماره">@context.Number</MudTd><MudTd DataLabel="عنوان">@context.Title</MudTd><MudTd><StatusChip Text="@context.Status" Color="@context.Color" /></MudTd><MudTd>@context.Time</MudTd></RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" lg="4">
        <MudPaper Class="dashboard-panel" Elevation="0">
            <div class="panel-heading"><MudText Typo="Typo.h6">کارتابل من</MudText><MudBadge Content="4" Color="Color.Error" /></div>
            @foreach (var task in Tasks)
            {
                <div class="task-row"><div class="task-dot"></div><div><strong>@task.Title</strong><small>@task.Meta</small></div><MudIcon Icon="@Icons.Material.Filled.ChevronLeft" /></div>
            }
        </MudPaper>
    </MudItem>
</MudGrid>
@code {
    [Parameter] public string Department { get; set; } = "";
    private readonly (string Label, string Value, string Trend, string Icon)[] Metrics =
    [
        ("پرونده‌های فعال", "۱۲۸", "۸٪ رشد این ماه", Icons.Material.Filled.FolderOpen),
        ("در انتظار اقدام", "۲۴", "۶ مورد فوری", Icons.Material.Filled.PendingActions),
        ("درخواست‌های جدید", "۱۸", "از ابتدای هفته", Icons.Material.Filled.PostAdd),
        ("تکمیل‌شده", "۴۷", "در ماه جاری", Icons.Material.Filled.TaskAlt)
    ];
    private readonly List<Activity> Activities =
    [
        new("PF-2026-000128", "تأمین شیرآلات واحد تقطیر", "در واحد خرید", Color.Primary, "۱۲ دقیقه پیش"),
        new("PF-2026-000127", "خرید پمپ سانتریفیوژ", "بررسی فنی", Color.Warning, "۴۵ دقیقه پیش"),
        new("PF-2026-000125", "قطعات یدکی کمپرسور", "تکمیل‌شده", Color.Success, "۲ ساعت پیش")
    ];
    private readonly (string Title, string Meta)[] Tasks =
    [
        ("بررسی مشخصات فنی پمپ", "موعد: امروز"),
        ("تأیید استعلام تأمین‌کنندگان", "اولویت بالا"),
        ("ارسال پرونده به کمیسیون", "PF-2026-000119"),
        ("تکمیل مستندات قرارداد", "موعد: فردا")
    ];
    private sealed record Activity(string Number, string Title, string Status, Color Color, string Time);
}
