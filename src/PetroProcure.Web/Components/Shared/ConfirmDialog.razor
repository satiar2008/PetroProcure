<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Title</MudText>
        <MudText Typo="Typo.body2" Class="mt-3">@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">انصراف</MudButton>
        <MudButton Color="@ConfirmColor" Variant="Variant.Filled" OnClick="Confirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "تأیید عملیات";
    [Parameter] public string Message { get; set; } = "آیا از انجام این عملیات مطمئن هستید؟";
    [Parameter] public string ConfirmText { get; set; } = "تأیید";
    [Parameter] public Color ConfirmColor { get; set; } = Color.Primary;
    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
