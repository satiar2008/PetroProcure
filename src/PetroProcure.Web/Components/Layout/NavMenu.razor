@inject IUserAccessContext Access
@implements IDisposable

<div class="drawer-header">
    <div class="drawer-brand">
        <img class="drawer-logo" src="/logo/logo.png" alt="PetroProcure" />
        <div>
            <MudText Typo="Typo.overline">پنل فعال</MudText>
            <DepartmentBadge Title="@Access.CurrentPanel.Title" Icon="@Access.CurrentPanel.Icon" />
        </div>
    </div>
</div>

<MudNavMenu Class="nav-menu">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">نمای کلی</MudNavLink>
    <MudText Typo="Typo.caption" Class="nav-section-title">عملیات واحد</MudText>
    @foreach (var item in VisibleDepartmentItems)
    {
        <MudNavLink Href="@item.Route" Match="NavLinkMatch.Prefix" Icon="@item.Icon">@item.Title</MudNavLink>
    }
    <MudText Typo="Typo.caption" Class="nav-section-title">ابزارهای مشترک</MudText>
    @foreach (var item in SharedItems)
    {
        <MudNavLink Href="@item.Route" Match="NavLinkMatch.Prefix" Icon="@item.Icon">@item.Title</MudNavLink>
    }
</MudNavMenu>

<div class="drawer-footer">
    <MudPaper Outlined="true" Class="support-card animated-card">
        <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Color="Color.Primary" />
        <div><strong>راهنمای سامانه</strong><small>نسخه آزمایشی ۰.۱</small></div>
    </MudPaper>
</div>

@code {
    protected override void OnInitialized()
    {
        Access.Changed += OnAccessChanged;
    }

    private IEnumerable<NavigationAccess> VisibleDepartmentItems =>
        NavigationAccessPolicy.VisibleForDepartment(
            Access.NavigationItems, Access.CurrentPanel.Key, Access.HasPermission);
    private IEnumerable<NavigationAccess> SharedItems =>
        NavigationAccessPolicy.VisibleShared(Access.NavigationItems, Access.HasPermission);

    private void OnAccessChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Access.Changed -= OnAccessChanged;
    }
}
