@inherits LayoutComponentBase
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject IAuthService Auth

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudRTLProvider RightToLeft="true">
<MudLayout>
    <MudAppBar Elevation="0" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="ToggleDrawer" />
        <div class="brand-block">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">PP</MudAvatar>
            <div>
                <MudText Typo="Typo.subtitle1" Class="brand-title">پتروپروکیور</MudText>
                <MudText Typo="Typo.caption" Class="brand-subtitle">سامانه یکپارچه تدارکات و خرید</MudText>
            </div>
        </div>
        <MudSpacer />
        @if (Access.Panels.Count > 1)
        {
            <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudButton Variant="Variant.Text" Color="Color.Inherit"
                               StartIcon="@Icons.Material.Filled.Apartment"
                               EndIcon="@Icons.Material.Filled.ExpandMore">
                        @Access.CurrentPanel.Title
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    @foreach (var panel in Access.Panels)
                    {
                        <MudMenuItem Icon="@panel.Icon" OnClick="@(() => SwitchPanel(panel))">
                            @panel.Title
                        </MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
        }
        <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone" Color="Color.Inherit" />
        <MudMenu Dense="true" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
            <ActivatorContent>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="profile-button">
                    <MudAvatar Size="Size.Small" Color="Color.Secondary">م‌ا</MudAvatar>
                    <span class="profile-copy">
                        <strong>@Access.DisplayName</strong>
                        <small>@Access.RoleTitle</small>
                    </span>
                    <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.PersonOutline">پروفایل کاربری</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Settings">تنظیمات</MudMenuItem>
                <MudDivider />
                <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">خروج از سامانه</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Elevation="1"
               Breakpoint="Breakpoint.Md" Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="content-container">
            <div class="breadcrumb-bar">
                <MudBreadcrumbs Items="_breadcrumbs" Separator="/" />
            </div>
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
</MudRTLProvider>

<div id="blazor-error-ui" data-nosnippet>
    خطای پیش‌بینی‌نشده رخ داد.
    <a href="." class="reload">بارگذاری مجدد</a>
</div>

@code {
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0B6B69",
            Secondary = "#D69B2D",
            Background = "#F4F7F8",
            Surface = "#FFFFFF",
            AppbarBackground = "#083F46",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#19343A",
            TextSecondary = "#60777C"
        },
        Typography = new Typography { Default = new DefaultTypography { FontFamily = ["Vazirmatn", "Tahoma", "sans-serif"] } },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "10px", DrawerWidthLeft = "280px" }
    };
    private List<BreadcrumbItem> _breadcrumbs = [new("خانه", href: "/"), new("داشبورد", href: null, disabled: true)];
    protected override void OnInitialized()
    {
        Access.Changed += OnAccessChanged;
        Navigation.LocationChanged += OnLocationChanged;
        UpdateBreadcrumbs();
    }
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void SwitchPanel(DepartmentAccess panel)
    {
        Access.SwitchPanel(panel.Key);
        Navigation.NavigateTo(panel.Route);
    }
    private void OnAccessChanged() => InvokeAsync(StateHasChanged);
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) { UpdateBreadcrumbs(); InvokeAsync(StateHasChanged); }
    private void UpdateBreadcrumbs()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0];
        _breadcrumbs = path switch
        {
            "" => [new("خانه", href: null, disabled: true)],
            "purchase" => Crumbs(("خانه", "/"), ("واحد خرید", null)),
            "purchase/files" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("پرونده‌های خرید", null)),
            var p when p.StartsWith("purchase/files/") => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("پرونده‌های خرید", "/purchase/files"), ("جزئیات پرونده", null)),
            "purchase/inquiries" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("استعلام‌ها", null)),
            "purchase/inquiries/create" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("استعلام‌ها", "/purchase/inquiries"), ("ایجاد استعلام", null)),
            var p when p.StartsWith("purchase/inquiries/") => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("استعلام‌ها", "/purchase/inquiries"), ("جزئیات استعلام", null)),
            "purchase/suppliers" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("تأمین‌کنندگان", null)),
            "purchase/suppliers/create" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("تأمین‌کنندگان", "/purchase/suppliers"), ("ایجاد تأمین‌کننده", null)),
            "purchase/suppliers/categories" => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("تأمین‌کنندگان", "/purchase/suppliers"), ("دسته‌بندی‌ها", null)),
            var p when p.StartsWith("purchase/suppliers/") => Crumbs(("خانه", "/"), ("واحد خرید", "/purchase"), ("تأمین‌کنندگان", "/purchase/suppliers"), ("جزئیات تأمین‌کننده", null)),
            "orders" => Crumbs(("خانه", "/"), ("سفارشات و کنترل موجودی", null)),
            "orders/mesc" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("کاتالوگ MESC", null)),
            "orders/mesc/groups" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("کاتالوگ MESC", "/orders/mesc"), ("گروه‌های عمومی", null)),
            "orders/mesc/items" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("کاتالوگ MESC", "/orders/mesc"), ("اقلام کالا", null)),
            "orders/mesc/grouped" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("کاتالوگ MESC", "/orders/mesc"), ("نمای گروه‌بندی", null)),
            "orders/indents" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("تقاضاهای خرید", null)),
            "orders/indents/create" => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("تقاضاهای خرید", "/orders/indents"), ("ایجاد تقاضا", null)),
            var p when p.StartsWith("orders/indents/") => Crumbs(("خانه", "/"), ("سفارشات", "/orders"), ("تقاضاهای خرید", "/orders/indents"), ("جزئیات تقاضا", null)),
            "inbox/my" => Crumbs(("خانه", "/"), ("کارتابل", null), ("کارتابل من", null)),
            "inbox/department" => Crumbs(("خانه", "/"), ("کارتابل", null), ("کارتابل واحد", null)),
            var p when p.StartsWith("inbox/tasks/") => Crumbs(("خانه", "/"), ("کارتابل", "/inbox/my"), ("جزئیات کار", null)),
            "admin" => Crumbs(("خانه", "/"), ("مدیریت سامانه", null)),
            var p when p.StartsWith("admin/") => Crumbs(("خانه", "/"), ("مدیریت سامانه", "/admin"), (AdminTitle(p), null)),
            "warehouse" => Crumbs(("خانه", "/"), ("انبار", null)),
            "applicant" => Crumbs(("خانه", "/"), ("متقاضی", null)),
            "tender-commission" => Crumbs(("خانه", "/"), ("کمیسیون مناقصه", null)),
            "reports" => Crumbs(("خانه", "/"), ("گزارش‌ها", null)),
            "ai" => Crumbs(("خانه", "/"), ("دستیار هوشمند", null)),
            _ => Crumbs(("خانه", "/"), ("داشبورد", null))
        };
    }

    private static List<BreadcrumbItem> Crumbs(params (string Text, string? Href)[] items) =>
        items.Select(item => new BreadcrumbItem(item.Text, item.Href, disabled: item.Href is null)).ToList();

    private static string AdminTitle(string path) => path switch
    {
        "admin/users" => "کاربران",
        "admin/roles" => "نقش‌ها",
        "admin/departments" => "واحدهای سازمانی",
        "admin/permissions" => "مجوزها",
        "admin/workflow-matrix" => "ماتریس گردش کار",
        "admin/settings" => "تنظیمات سیستم",
        "admin/audit-log" => "گزارش ممیزی",
        _ => "مدیریت"
    };
    public void Dispose()
    {
        Access.Changed -= OnAccessChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
