@page "/orders/indents"
@rendermode InteractiveServer
@implements IDisposable
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
<PageTitle>تقاضاهای خرید</PageTitle>
<PageHeader Title="تقاضاهای خرید" Subtitle="ثبت، پیگیری و ارسال تقاضا به واحد خرید">
    <Actions>@if(IndentUiPolicy.CanCreate(Access.HasPermission)){<MudButton Href="/orders/indents/create" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">تقاضای جدید</MudButton>}</Actions>
</PageHeader>
@if(_loading){<LoadingOverlay Visible="true" />}
else if(_error is not null){<EmptyState Title="خطا در دریافت تقاضاها" Description="@_error"><Action><MudButton OnClick="Load">تلاش مجدد</MudButton></Action></EmptyState>}
else{
<MudPaper Class="filter-panel" Elevation="0"><MudGrid>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="_number" Label="شماره تقاضا" Immediate="true" /></MudItem>
    <MudItem xs="12" md="3"><MudTextField @bind-Value="_title" Label="عنوان" Immediate="true" /></MudItem>
    <MudItem xs="12" md="2"><MudSelect T="IndentStatus?" @bind-Value="_status" Label="وضعیت" Clearable="true">@foreach(var s in Enum.GetValues<IndentStatus>()){<MudSelectItem T="IndentStatus?" Value="@s">@IndentUiPolicy.StatusText(s)</MudSelectItem>}</MudSelect></MudItem>
    <MudItem xs="12" md="2"><MudSelect T="IndentType?" @bind-Value="_type" Label="نوع" Clearable="true">@foreach(var t in Enum.GetValues<IndentType>()){<MudSelectItem T="IndentType?" Value="@t">@IndentUiPolicy.TypeText(t)</MudSelectItem>}</MudSelect></MudItem>
    <MudItem xs="12" md="2"><MudSelect T="Guid?" @bind-Value="_department" Label="واحد درخواست‌کننده" Clearable="true">@foreach(var d in FakeDirectory.Departments){<MudSelectItem T="Guid?" Value="@d.Id">@d.Name</MudSelectItem>}</MudSelect></MudItem>
    <MudItem xs="12" md="3"><MudDatePicker @bind-Date="_from" Label="از تاریخ" /></MudItem><MudItem xs="12" md="3"><MudDatePicker @bind-Date="_to" Label="تا تاریخ" /></MudItem>
</MudGrid></MudPaper>
<MudPaper Class="data-panel" Elevation="0"><MudTable Items="Filtered" Dense="true" Hover="true" RowsPerPage="10">
<HeaderContent><MudTh>شماره تقاضا</MudTh><MudTh>عنوان</MudTh><MudTh>نوع تقاضا</MudTh><MudTh>منبع درخواست</MudTh><MudTh>واحد درخواست‌کننده</MudTh><MudTh>وضعیت</MudTh><MudTh>تاریخ ایجاد</MudTh><MudTh>عملیات</MudTh></HeaderContent>
<RowTemplate>
<MudTd><MudLink Href="@($"/orders/indents/{context.Id}")"><strong>@IndentUiPolicy.FormatNumber(context.IndentNumber)</strong></MudLink><MudText Typo="Typo.caption">@context.IndentNumber</MudText></MudTd>
<MudTd>@context.Title</MudTd><MudTd>@IndentUiPolicy.TypeText(context.IndentType)</MudTd><MudTd>@SourceCell(context)</MudTd><MudTd>@FakeDirectory.DepartmentName(context.RequestingDepartmentId)</MudTd>
<MudTd><StatusChip Text="@IndentUiPolicy.StatusText(context.Status)" /></MudTd><MudTd><DateDisplay Value="@context.CreatedAt" /></MudTd>
<MudTd><MudIconButton Icon="@Icons.Material.Filled.Visibility" Href="@($"/orders/indents/{context.Id}")" />
@if(IndentUiPolicy.CanEdit(context.Status,Access.HasPermission)){<MudIconButton Icon="@Icons.Material.Filled.Edit" Href="@($"/orders/indents/{context.Id}/edit")" />}
@if(IndentUiPolicy.CanSubmit(context.Status,Access.HasPermission)){<MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="@(()=>Action(context,"submit","ارسال تقاضا","تقاضا برای بررسی ارسال شود؟"))" />}
@if(IndentUiPolicy.CanApproveOrReject(context.Status,Access.HasPermission)){<MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" OnClick="@(()=>Action(context,"approve","تأیید تقاضا","تقاضا تأیید شود؟"))" /><MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" OnClick="@(()=>Reject(context))" />}
@if(IndentUiPolicy.CanSendToPurchase(context.Status,Access.HasPermission)){<MudIconButton Icon="@Icons.Material.Filled.ForwardToInbox" Color="Color.Info" OnClick="@(()=>Action(context,"send-to-purchase","ارسال به واحد خرید","تقاضا به واحد خرید ارسال شود؟"))" />}
@if(IndentUiPolicy.CanCreatePurchaseFile(context.Status,Access.HasPermission)){<MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder" Color="Color.Secondary" Href="@($"/purchase/files/from-indent/{context.Id}")" />}</MudTd>
</RowTemplate><NoRecordsContent><EmptyState Title="تقاضایی یافت نشد" Description="فیلترها را تغییر دهید یا تقاضای جدید ثبت کنید." /></NoRecordsContent>
<PagerContent><MudTablePager PageSizeOptions="new[]{10,25,50}" /></PagerContent></MudTable></MudPaper>}
@code{
private List<IndentSummaryDto>_items=[];private bool _loading=true;private string?_error,_number,_title;private IndentStatus?_status;private IndentType?_type;private Guid?_department;private DateTime?_from,_to;
private IEnumerable<IndentSummaryDto>Filtered=>_items.Where(x=>(string.IsNullOrWhiteSpace(_number)||x.IndentNumber.Contains(_number.Trim()))&&(string.IsNullOrWhiteSpace(_title)||x.Title.Contains(_title.Trim(),StringComparison.OrdinalIgnoreCase))&&(!_status.HasValue||x.Status==_status)&&(!_type.HasValue||x.IndentType==_type)&&(!_department.HasValue||x.RequestingDepartmentId==_department)&&(!_from.HasValue||x.CreatedAt.Date>=_from.Value.Date)&&(!_to.HasValue||x.CreatedAt.Date<=_to.Value.Date)).OrderByDescending(x=>x.CreatedAt);
private bool _disposed;
protected override async Task OnAfterRenderAsync(bool first){if(!first||_disposed)return;if(!IndentUiPolicy.CanView(Access.HasPermission)){Navigation.NavigateTo("/access-denied");return;}await Load();if(!_disposed)await InvokeAsync(StateHasChanged);}
private async Task Load(){if(_disposed)return;_loading=true;_error=null;try{_items=await Api.GetIndentsAsync();}catch(Exception ex){if(!_disposed){_error="امکان دریافت فهرست تقاضاها وجود ندارد.";Snackbar.Add(ex.Message,Severity.Error);}}finally{if(!_disposed)_loading=false;}}
private async Task Action(IndentSummaryDto item,string action,string title,string message){var d=await Dialog.ShowAsync<ConfirmDialog>(title,new DialogParameters{{"Message",message}});var r=await d.Result;if(r?.Canceled!=false)return;try{await Api.ChangeIndentStatusAsync(item.Id,action);Snackbar.Add("عملیات با موفقیت انجام شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private async Task Reject(IndentSummaryDto item){var d=await Dialog.ShowAsync<RejectIndentDialog>("رد تقاضا");var r=await d.Result;if(r?.Canceled!=false)return;try{await Api.ChangeIndentStatusAsync(item.Id,"reject");Snackbar.Add("تقاضا رد شد. توجه: Backend فعلی علت رد را ذخیره نمی‌کند.",Severity.Warning);await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private RenderFragment SourceCell(IndentSummaryDto item)=>@<span>@if(SourceRoute(item) is { } route){<MudLink Href="@route">@item.SourceDisplayText</MudLink>}else{@item.SourceDisplayText}</span>;
private static string? SourceRoute(IndentSummaryDto item)=>item.SourceType switch{IndentSourceType.MaterialNeed when item.SourceReferenceId.HasValue=>$"/orders/material-needs/{item.SourceReferenceId}",IndentSourceType.ShortageAlert=>"/orders/shortage-alerts",_=>null};
public void Dispose()=>_disposed=true;
}
