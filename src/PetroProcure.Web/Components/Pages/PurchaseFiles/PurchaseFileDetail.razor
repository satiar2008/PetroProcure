@page "/purchase/files/{Id:guid}"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar
@inject IUserAccessContext Access
@inject IDialogService Dialog
@inject IJSRuntime JS

<PageTitle>@(_summary.Data?.FileNumber ?? "پرونده خرید")</PageTitle>
@if (_summary.Loading) { <LoadingOverlay Visible="true" Text="در حال دریافت پرونده..." /> }
else if (_summary.Error is not null) { @ErrorState(_summary.Error, LoadSummary) }
else if (_summary.Data is { } file)
{
    <PageHeader Title="@file.Title" Subtitle="@file.FileNumber">
        <Actions><StatusChip Text="@PurchaseFileList.StatusText(file.Status)" Color="@PurchaseFileList.StatusColor(file.Status)" /></Actions>
    </PageHeader>
    <MudTabs Rounded="true" ApplyEffectsToContainer="true" PanelClass="detail-tab-panel" Elevation="0">
        <MudTabPanel Text="خلاصه" Icon="@Icons.Material.Filled.Dashboard">
            <MudPaper Class="form-panel" Elevation="0"><div class="summary-grid">
                <SummaryItem Label="شماره پرونده" Value="@file.FileNumber" />
                <SummaryItem Label="وضعیت" Value="@PurchaseFileList.StatusText(file.Status)" />
                <SummaryItem Label="اولویت" Value="@PurchaseFileList.PriorityText(file.Priority)" />
                <SummaryItem Label="واحد جاری" Value="@DepartmentName(file.CurrentDepartmentId)" />
                <div class="summary-item"><span>تاریخ ایجاد</span><strong><DateDisplay Value="@file.CreatedAt" /></strong></div>
                <SummaryItem Label="تعداد اقلام" Value="@file.Items.Count.ToString()" />
            </div><MudDivider Class="my-4" /><MudText Typo="Typo.subtitle2">شرح پرونده</MudText>
            <MudText Typo="Typo.body2">@(file.Description ?? "شرحی ثبت نشده است.")</MudText>
            <PermissionView Permission="@InquiryUiPolicy.Create">
                <MudButton Class="mt-4" Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.RequestQuote"
                           Href="@($"/purchase/inquiries/from-purchase-file/{file.Id}")">
                    ایجاد استعلام از پرونده خرید
                </MudButton>
            </PermissionView>
            <PermissionView Permission="@TenderUiPolicy.Create">
                <MudButton Class="mt-4 mx-2" Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Gavel"
                           Href="@($"/purchase/tenders/from-purchase-file/{file.Id}")">
                    ایجاد مناقصه از پرونده خرید
                </MudButton>
            </PermissionView>
            <PermissionView Permission="@ContractUiPolicy.Create">
                <MudButton Class="mt-4" Variant="Variant.Outlined" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.AssignmentTurnedIn"
                           Href="@($"/purchase/contracts/from-purchase-file/{file.Id}")">
                    ایجاد قرارداد از پرونده خرید
                </MudButton>
            </PermissionView>
            <PermissionView Permission="@PurchaseOrderUiPolicy.Create">
                <MudButton Class="mt-4 mx-2" Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ShoppingCart"
                           Href="@($"/purchase/purchase-orders/from-purchase-file/{file.Id}")">
                    ایجاد سفارش خرید از پرونده خرید
                </MudButton>
            </PermissionView></MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="اقلام" Icon="@Icons.Material.Filled.Inventory2">
            @TabBody(_items, LoadItems, ItemsContent)
        </MudTabPanel>

        <MudTabPanel Text="اسناد" Icon="@Icons.Material.Filled.Description">
            @TabBody(_documents, LoadDocuments, DocumentsContent)
        </MudTabPanel>

        <MudTabPanel Text="گردش کار" Icon="@Icons.Material.Filled.AccountTree">
            @TabBody(_workflow, LoadWorkflow, WorkflowContent)
        </MudTabPanel>

        <MudTabPanel Text="یادداشت‌ها" Icon="@Icons.Material.Filled.Notes">
            <MudPaper Class="form-panel mb-4" Elevation="0">
                <MudTextField @bind-Value="_noteText" Label="یادداشت جدید" Lines="3" Variant="Variant.Outlined" />
                <MudCheckBox @bind-Value="_internalNote" Label="یادداشت داخلی" />
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_noteBusy || string.IsNullOrWhiteSpace(_noteText)" OnClick="AddNote">ثبت یادداشت</MudButton>
            </MudPaper>
            @if (_notes.Loading) { <MudProgressLinear Indeterminate="true" /> }
            else if (_notes.Error is not null) { @ErrorState(_notes.Error, LoadNotes) }
            else if (_notes.Data is null || _notes.Data.Count == 0) { <EmptyState Title="یادداشتی وجود ندارد" Description="اولین یادداشت پرونده را ثبت کنید." /> }
            else { @foreach (var note in _notes.Data.OrderByDescending(x=>x.CreatedAt)) {
                <MudAlert Severity="@(note.IsInternal ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined" Class="mb-2">
                    @note.NoteText<br /><small><DepartmentDisplay DepartmentId="@note.DepartmentId" /> · <DateDisplay Value="@note.CreatedAt" IncludeTime="true" /></small>
                </MudAlert> } }
        </MudTabPanel>

        <MudTabPanel Text="گزارش‌ها" Icon="@Icons.Material.Filled.Assessment">
            <MudPaper Class="form-panel" Elevation="0">
                <MudText Typo="Typo.h6">گزارش خلاصه پرونده خرید</MudText>
                <div class="report-actions mt-4">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Preview" Disabled="_reportLoading" OnClick="TogglePurchaseFilePreview">پیش‌نمایش</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="_reportLoading" OnClick="OpenPurchaseFilePdf">خروجی PDF</MudButton>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.SaveAlt" Disabled="_savingReport" OnClick="SaveReport">ذخیره در اسناد پرونده</MudButton>
                </div>
                @if (_reportLoading) { <MudProgressLinear Indeterminate="true" Class="mt-4" /> }
                @if (_showPreview && _purchaseFilePdfDataUrl is not null) { <div class="report-preview"><iframe src="@_purchaseFilePdfDataUrl" title="پیش‌نمایش گزارش"></iframe></div> }
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="قراردادها" Icon="@Icons.Material.Filled.AssignmentTurnedIn">
            @TabBody(_contracts, LoadContracts, ContractsContent)
        </MudTabPanel>

        <MudTabPanel Text="سفارش‌های خرید" Icon="@Icons.Material.Filled.ShoppingCart">
            @TabBody(_purchaseOrders, LoadPurchaseOrders, PurchaseOrdersContent)
        </MudTabPanel>

        <MudTabPanel Text="دستیار هوشمند" Icon="@Icons.Material.Filled.AutoAwesome">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">نتایج هوش مصنوعی صرفاً پیشنهاد و تحلیل هستند و تصمیم نهایی بر عهده کاربران مجاز و کمیسیون‌ها است.</MudAlert>
            <div class="report-actions mb-4">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_aiBusy" OnClick="@(()=>RunAi("summarize"))">خلاصه پرونده</MudButton>
                <MudButton Variant="Variant.Outlined" Disabled="_aiBusy" OnClick="@(()=>RunAi("check-missing-documents"))">بررسی نقص مدارک</MudButton>
                <MudButton Variant="Variant.Outlined" Disabled="_aiBusy" OnClick="@(()=>RunAi("evaluate-rules"))">بررسی قوانین خرید</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="_aiBusy" OnClick="EvaluateTenderLegalRules">بررسی قوانین مناقصه</MudButton>
            </div>
            @if (_ai.Loading || _aiBusy) { <MudProgressLinear Indeterminate="true" /> }
            else if (_ai.Error is not null) { @ErrorState(_ai.Error, LoadAi) }
            else if (_ai.Data is null || _ai.Data.Count == 0) { <EmptyState Title="هنوز تحلیلی انجام نشده" Description="یکی از عملیات بالا را اجرا کنید." /> }
            else { @foreach(var evaluation in _ai.Data.OrderByDescending(x=>x.CreatedAt)) {
                <MudPaper Class="ai-result-card mb-3" Elevation="0"><MudText Typo="Typo.h6">@AiType(evaluation.EvaluationType)</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@evaluation.Summary</MudText>
                @foreach(var finding in evaluation.Findings){<MudAlert Severity="@AiSeverity(finding.Severity)" Variant="Variant.Outlined" Class="mb-2"><strong>@finding.Title</strong><br/>@finding.Description</MudAlert>}
                @foreach(var recommendation in evaluation.Recommendations){<div class="ai-recommendation"><MudIcon Icon="@Icons.Material.Filled.Lightbulb" /><div><strong>@recommendation.Title</strong><span>@recommendation.Description</span></div></div>}
                </MudPaper> } }
            <MudDivider Class="my-4" />
            <AiEvaluationPanel EntityType="PurchaseFile" EntityId="Id" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private readonly TabLoadState<PurchaseFileDto> _summary = new();
    private readonly TabLoadState<List<PurchaseFileGroupedItemsDto>> _items = new();
    private readonly TabLoadState<List<FileDocumentDto>> _documents = new();
    private readonly TabLoadState<PurchaseFileWorkflowStateDto> _workflow = new();
    private readonly TabLoadState<List<WorkflowActionDto>> _workflowActions = new();
    private readonly TabLoadState<List<PurchaseFileNoteDto>> _notes = new();
    private readonly TabLoadState<List<AiEvaluationResultDto>> _ai = new();
    private readonly TabLoadState<List<PurchaseContractSummaryDto>> _contracts = new();
    private readonly TabLoadState<List<PurchaseOrderSummaryDto>> _purchaseOrders = new();
    private bool _showPreview, _savingReport, _aiBusy, _noteBusy, _internalNote, _reportLoading;
    private string? _noteText, _mescSearch, _documentDescription; private List<MescItemDto> _mescResults = [];
    private string? _purchaseFilePdfDataUrl;
    private DocumentType _documentType = DocumentType.TechnicalSpecification;
    private DocumentUploadLimitsDto? _uploadLimits; private bool _uploadBusy;
    private string? _workflowComment;
    private bool Editable => _summary.Data?.Status is not PurchaseFileStatus.Completed and not PurchaseFileStatus.Archived;
    private bool CanEdit => _summary.Data is { } value && PurchaseFileUiPolicy.CanEdit(value.Status, Access.HasPermission);

    protected override async Task OnParametersSetAsync()
    {
        await LoadSummary();
        _ = LoadItems(); _ = LoadDocuments(); _ = LoadWorkflow(); _ = LoadNotes(); _ = LoadAi(); _ = LoadContracts(); _ = LoadPurchaseOrders();
    }
    private async Task LoadSummary() => await Load(_summary, async () =>
        await Api.GetPurchaseFileAsync(Id) ?? throw new HttpRequestException("پرونده یافت نشد."), "خلاصه پرونده دریافت نشد.");
    private async Task LoadItems() => await Load(_items, () => Api.GetGroupedItemsAsync(Id), "اقلام پرونده دریافت نشد.");
    private async Task LoadDocuments(){await Load(_documents, () => Api.GetDocumentsAsync(Id), "اسناد پرونده دریافت نشد.");try{_uploadLimits??=await Api.GetUploadLimitsAsync();}catch{}}
    private async Task LoadWorkflow()
    {
        await Task.WhenAll(
            Load(_workflow, () => Api.GetWorkflowStateAsync(Id), "گردش کار دریافت نشد."),
            Load(_workflowActions, () => Api.GetAllowedWorkflowActionsAsync(Id), "اقدامات مجاز دریافت نشد."));
    }
    private async Task LoadNotes()
    {
        var state = new TabLoadState<PurchaseFileDto>();
        await Load(state, async () => await Api.GetPurchaseFileAsync(Id)
            ?? throw new HttpRequestException("پرونده یافت نشد."), "یادداشت‌ها دریافت نشد.");
        _notes.Loading = false; _notes.Error = state.Error; _notes.Data = state.Data?.Notes.ToList() ?? [];
    }
    private async Task LoadAi() => await Load(_ai, () => Api.GetAiEvaluationsAsync(Id), "نتایج هوش مصنوعی دریافت نشد.");
    private async Task LoadContracts() => await Load(_contracts, () => Api.GetPurchaseFileContractsAsync(Id), "قراردادهای پرونده دریافت نشد.");
    private async Task LoadPurchaseOrders() => await Load(_purchaseOrders, () => Api.GetPurchaseFilePurchaseOrdersAsync(Id), "سفارش‌های خرید پرونده دریافت نشد.");
    private async Task Load<T>(TabLoadState<T> state, Func<Task<T>> loader, string message)
    {
        state.Loading = true; state.Error = null; StateHasChanged();
        try { state.Data = await loader(); if (state.Data is null) state.Error = message; }
        catch (Exception ex) { state.Error = message; Snackbar.Add(ex.Message, Severity.Error); }
        finally { state.Loading = false; StateHasChanged(); }
    }
    private RenderFragment ErrorState(string error, Func<Task> retry) => @<EmptyState Icon="@Icons.Material.Filled.CloudOff" Title="دریافت اطلاعات ناموفق بود" Description="@error"><Action><MudButton OnClick="retry">تلاش مجدد</MudButton></Action></EmptyState>;
    private RenderFragment TabBody<T>(TabLoadState<T> state, Func<Task> retry, RenderFragment<T> content) => builder =>
    {
        if (state.Loading) builder.AddContent(0, (RenderFragment)(b => { b.OpenComponent<MudProgressLinear>(0); b.AddAttribute(1, "Indeterminate", true); b.CloseComponent(); }));
        else if (state.Error is not null) builder.AddContent(1, ErrorState(state.Error, retry));
        else if (state.Data is not null) builder.AddContent(2, content(state.Data));
    };
    private RenderFragment<List<PurchaseFileGroupedItemsDto>> ItemsContent => groups => @<div>
        @if (CanEdit) {
            <MudPaper Class="form-panel mb-4" Elevation="0"><MudTextField @bind-Value="_mescSearch" Label="جستجوی قلم MESC" Variant="Variant.Outlined" />
            <MudButton OnClick="SearchMesc" Variant="Variant.Outlined">جستجو</MudButton>
            @foreach(var result in _mescResults){<div class="d-flex justify-space-between align-center mt-2"><span>@result.Code - @result.SpecificDescription</span><MudButton Size="Size.Small" OnClick="@(()=>AddItem(result))">افزودن</MudButton></div>}</MudPaper>
        }
        @if(groups.Count==0){<EmptyState Title="قلمی ثبت نشده" Description="اقلام مورد نیاز را به پرونده اضافه کنید." />}
        @foreach(var group in groups){<MudPaper Class="item-group" Elevation="0"><div class="group-header"><div><strong>@group.MescGeneralGroupCode</strong><span>@group.GeneralDescription</span></div></div>
        <MudTable Items="group.Items" Dense="true"><HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح اختصاصی</MudTh><MudTh>درخواستی</MudTh><MudTh>تأییدشده</MudTh><MudTh></MudTh></HeaderContent>
        <RowTemplate><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.RequestedQuantity</MudTd><MudTd>@context.ApprovedQuantity</MudTd>
        <MudTd>@if(CanEdit){<MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(()=>RemoveItem(context.Id))" />}</MudTd></RowTemplate></MudTable></MudPaper>}
    </div>;
    private RenderFragment<List<FileDocumentDto>> DocumentsContent => docs => @<div>
        @if(CanEdit){<MudPaper Class="form-panel mb-4" Elevation="0"><MudGrid>
            <MudItem xs="12" md="4"><MudSelect T="DocumentType" @bind-Value="_documentType" Label="نوع سند">@foreach(var type in Enum.GetValues<DocumentType>()){<MudSelectItem Value="@type">@DocumentTypeText(type)</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="5"><MudTextField @bind-Value="_documentDescription" Label="توضیحات سند" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><InputFile OnChange="UploadDocument" disabled="@_uploadBusy" /></MudItem>
        </MudGrid>@if(_uploadLimits is not null){<MudText Typo="Typo.caption">حداکثر @_uploadLimits.MaxFileSizeMb مگابایت؛ پسوندهای مجاز: @string.Join("، ",_uploadLimits.AllowedExtensions)</MudText>}</MudPaper>}
        @if(docs.Count==0){<EmptyState Title="سندی ثبت نشده است" Description="فایل مورد نظر را با نوع سند مناسب بارگذاری کنید." />}
        else {<MudTable Items="docs"><HeaderContent><MudTh>نام فایل</MudTh><MudTh>نوع</MudTh><MudTh>نسخه</MudTh><MudTh>حجم</MudTh><MudTh>بارگذار</MudTh><MudTh>تاریخ</MudTh><MudTh></MudTh></HeaderContent>
        <RowTemplate><MudTd>@context.OriginalFileName</MudTd><MudTd>@DocumentTypeText(context.DocumentType)</MudTd><MudTd>@context.VersionNo</MudTd><MudTd>@FormatSize(context.Size)</MudTd><MudTd><UserDisplay UserId="@context.UploadedByUserId" /></MudTd><MudTd><DateDisplay Value="@context.UploadedAt" /></MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Download" OnClick="@(()=>DownloadDocument(context.Id))" />@if(CanEdit){<label class="mud-button-root mud-icon-button"><InputFile OnChange="@(e=>UploadVersion(context.Id,e))" style="display:none" /><MudIcon Icon="@Icons.Material.Filled.UploadFile" /></label><MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(()=>DeleteDocument(context.Id))" />}</MudTd></RowTemplate></MudTable>}
    </div>;
    private RenderFragment<List<PurchaseContractSummaryDto>> ContractsContent => contracts => @<div>
        <div class="d-flex justify-end mb-3">
            <PermissionView Permission="@ContractUiPolicy.Create">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                           Href="@($"/purchase/contracts/from-purchase-file/{Id}")">ایجاد قرارداد</MudButton>
            </PermissionView>
        </div>
        @if (contracts.Count == 0)
        {
            <EmptyState Title="قراردادی ثبت نشده" Description="برای این پرونده خرید هنوز قراردادی ایجاد نشده است." />
        }
        else
        {
            <MudTable Items="contracts" Dense="true" Hover="true">
                <HeaderContent><MudTh>شماره قرارداد</MudTh><MudTh>تأمین‌کننده</MudTh><MudTh>عنوان</MudTh><MudTh>نوع</MudTh><MudTh>وضعیت</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>تاریخ ایجاد</MudTh><MudTh></MudTh></HeaderContent>
                <RowTemplate>
                    <MudTd>@context.ContractNumber</MudTd>
                    <MudTd>@context.SupplierName</MudTd>
                    <MudTd>@context.Title</MudTd>
                    <MudTd>@ContractUiPolicy.TypeText(context.ContractType)</MudTd>
                    <MudTd><StatusChip Text="@ContractUiPolicy.StatusText(context.Status)" /></MudTd>
                    <MudTd>@(context.FinalAmount?.ToString("N0") ?? "—") @context.Currency</MudTd>
                    <MudTd><DateDisplay Value="@context.CreatedAt" /></MudTd>
                    <MudTd><MudButton Size="Size.Small" Href="@($"/purchase/contracts/{context.Id}")">مشاهده</MudButton></MudTd>
                </RowTemplate>
            </MudTable>
        }
    </div>;
    private RenderFragment<List<PurchaseOrderSummaryDto>> PurchaseOrdersContent => orders => @<div>
        <div class="d-flex justify-end mb-3">
            <PermissionView Permission="@PurchaseOrderUiPolicy.Create">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                           Href="@($"/purchase/purchase-orders/from-purchase-file/{Id}")">ایجاد سفارش خرید</MudButton>
            </PermissionView>
        </div>
        @if (orders.Count == 0)
        {
            <EmptyState Title="سفارش خریدی ثبت نشده" Description="برای این پرونده خرید هنوز سفارش خرید ایجاد نشده است." />
        }
        else
        {
            <MudTable Items="orders" Dense="true" Hover="true">
                <HeaderContent><MudTh>شماره سفارش</MudTh><MudTh>قرارداد</MudTh><MudTh>تأمین‌کننده</MudTh><MudTh>نوع</MudTh><MudTh>وضعیت</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>موعد تحویل</MudTh><MudTh></MudTh></HeaderContent>
                <RowTemplate>
                    <MudTd>@context.PurchaseOrderNumber</MudTd>
                    <MudTd>@(context.ContractNumber ?? "—")</MudTd>
                    <MudTd>@context.SupplierName</MudTd>
                    <MudTd>@PurchaseOrderUiPolicy.TypeText(context.PurchaseOrderType)</MudTd>
                    <MudTd><StatusChip Text="@PurchaseOrderUiPolicy.StatusText(context.Status)" Color="@PurchaseOrderUiPolicy.StatusColor(context.Status)" /></MudTd>
                    <MudTd>@(context.FinalAmount?.ToString("N0") ?? "—") @context.Currency</MudTd>
                    <MudTd><DateDisplay Value="@context.ExpectedDeliveryDate" /></MudTd>
                    <MudTd><MudButton Size="Size.Small" Href="@($"/purchase/purchase-orders/{context.Id}")">مشاهده</MudButton></MudTd>
                </RowTemplate>
            </MudTable>
        }
    </div>;
    private RenderFragment<PurchaseFileWorkflowStateDto> WorkflowContent => state => @<div>
        <MudPaper Class="form-panel mb-4" Elevation="0"><MudText>واحد جاری: <DepartmentDisplay DepartmentId="@state.CurrentDepartmentId" /></MudText><MudText>وضعیت: @PurchaseFileList.StatusText(Enum.Parse<PurchaseFileStatus>(state.Status))</MudText>
        @if(_workflowActions.Loading){<MudProgressLinear Indeterminate="true" />}
        else if(_workflowActions.Error is not null){@ErrorState(_workflowActions.Error,LoadWorkflow)}
        else if(_workflowActions.Data is null||_workflowActions.Data.Count==0){<MudAlert Severity="Severity.Info" Class="mt-3">در وضعیت فعلی اقدامی برای شما مجاز نیست.</MudAlert>}
        else {
            <MudTextField @bind-Value="_workflowComment" Label="توضیحات اقدام" Lines="2" Variant="Variant.Outlined" Class="mt-3" />
            <div class="report-actions mt-3">@foreach(var action in _workflowActions.Data){
                <MudButton Color="@(action.IsFinalAction?Color.Success:action.IsReturnAction?Color.Warning:Color.Primary)"
                           Variant="Variant.Filled" OnClick="@(()=>ExecuteMatrixAction(action))">@action.Title</MudButton>
            }</div>
        }
        </MudPaper>
        @if(state.Steps.Count==0){<EmptyState Title="گردش کاری ثبت نشده" Description="پس از شروع گردش، اقدامات اینجا نمایش داده می‌شوند." />}
        @foreach(var step in state.Steps.OrderByDescending(x=>x.CreatedAt)){<div class="timeline-row"><div class="timeline-marker"></div><div><strong>@step.ActionName</strong><small><DepartmentDisplay DepartmentId="@step.FromDepartmentId" /> ← <DepartmentDisplay DepartmentId="@step.ToDepartmentId" /> · <DateDisplay Value="@step.CreatedAt" IncludeTime="true" /></small></div></div>}
    </div>;
    private async Task AddNote(){_noteBusy=true;try{var department=_summary.Data!.CurrentDepartmentId;var note=await Api.AddNoteAsync(Id,new(department,_noteText!,_internalNote));_notes.Data??=[];_notes.Data.Insert(0,note);_noteText=null;Snackbar.Add("یادداشت ثبت شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}finally{_noteBusy=false;}}
    private async Task UploadDocument(InputFileChangeEventArgs e){_uploadBusy=true;try{var file=e.File;var max=(_uploadLimits?.MaxFileSizeMb??25)*1024L*1024L;await using var stream=file.OpenReadStream(max);await Api.UploadDocumentAsync(Id,stream,file.Name,file.ContentType,new(_documentType,_summary.Data?.CurrentDepartmentId,_documentDescription));await LoadDocuments();_documentDescription=null;Snackbar.Add("سند بارگذاری شد.",Severity.Success);}catch(Exception ex){Snackbar.Add("بارگذاری ناموفق بود: "+ex.Message,Severity.Error);}finally{_uploadBusy=false;}}
    private async Task DownloadDocument(Guid documentId){try{var file=await Api.DownloadDocumentAsync(documentId);await JS.InvokeVoidAsync("petroProcureDownloadFile",file.Content,file.ContentType,file.FileName);}catch(Exception ex){Snackbar.Add("دانلود سند ناموفق بود: "+ex.Message,Severity.Error);}}
    private async Task UploadVersion(Guid documentId,InputFileChangeEventArgs e){try{var file=e.File;var max=(_uploadLimits?.MaxFileSizeMb??25)*1024L*1024L;await using var stream=file.OpenReadStream(max);await Api.UploadDocumentVersionAsync(documentId,stream,file.Name,file.ContentType);await LoadDocuments();Snackbar.Add("نسخه جدید ثبت شد.",Severity.Success);}catch(Exception ex){Snackbar.Add("ثبت نسخه ناموفق بود: "+ex.Message,Severity.Error);}}
    private async Task DeleteDocument(Guid documentId){var dialog=await Dialog.ShowAsync<ConfirmDialog>("حذف سند",new DialogParameters{{"Message","سند به صورت نرم حذف شود؟"},{"ConfirmColor",Color.Error}});var result=await dialog.Result;if(result is null||result.Canceled)return;try{await Api.DeleteDocumentAsync(documentId);await LoadDocuments();Snackbar.Add("سند حذف شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
    private async Task SearchMesc(){if(string.IsNullOrWhiteSpace(_mescSearch))return;_mescResults=await Api.SearchMescItemsAsync(_mescSearch);}
    private async Task AddItem(MescItemDto item){try{await Api.AddPurchaseFileItemAsync(Id,new(item.Id,FakeDirectory.UnitId(item.UnitOfMeasure),1,1,null));await LoadItems();Snackbar.Add("قلم اضافه شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
    private async Task RemoveItem(Guid itemId){var dialog=await Dialog.ShowAsync<ConfirmDialog>("حذف قلم",new DialogParameters{{"Message","قلم از پرونده حذف شود؟"},{"ConfirmColor",Color.Error}});var result=await dialog.Result;if(result is null||result.Canceled)return;try{await Api.RemovePurchaseFileItemAsync(Id,itemId);await LoadItems();Snackbar.Add("قلم حذف شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
    private async Task StartWorkflow(){try{await Api.StartWorkflowAsync(new("PurchaseFile",Id,_summary.Data!.CurrentDepartmentId));await LoadWorkflow();Snackbar.Add("گردش کار آغاز شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
    private async Task ExecuteMatrixAction(WorkflowActionDto action)
    {
        if(action.RequiresComment&&string.IsNullOrWhiteSpace(_workflowComment)){Snackbar.Add("ثبت توضیحات برای این اقدام الزامی است.",Severity.Warning);return;}
        var dialog=await Dialog.ShowAsync<ConfirmDialog>("تأیید اقدام گردش کار",new DialogParameters{{"Message",$"اقدام «{action.Title}» انجام شود؟"},{"ConfirmColor",action.IsFinalAction?Color.Success:Color.Primary}});
        var confirmation=await dialog.Result;if(confirmation is null||confirmation.Canceled)return;
        try{await Api.ExecuteWorkflowActionAsync(Id,new(action.Code,_workflowComment));_workflowComment=null;await Task.WhenAll(LoadWorkflow(),LoadSummary());Snackbar.Add("اقدام گردش کار با موفقیت انجام شد.",Severity.Success);}
        catch(Exception ex){Snackbar.Add("اجرای اقدام ناموفق بود: "+ex.Message,Severity.Error);}
    }
    private async Task SaveReport(){_savingReport=true;try{await Api.SavePurchaseFileSummaryAsync(Id);await LoadDocuments();Snackbar.Add("گزارش در اسناد ذخیره شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}finally{_savingReport=false;}}
    private async Task TogglePurchaseFilePreview(){_showPreview=!_showPreview;if(_showPreview)await EnsurePurchaseFilePdfLoaded();}
    private async Task OpenPurchaseFilePdf(){await EnsurePurchaseFilePdfLoaded();if(_purchaseFilePdfDataUrl is not null)await JS.InvokeVoidAsync("open",_purchaseFilePdfDataUrl,"_blank");}
    private async Task EnsurePurchaseFilePdfLoaded(){if(_purchaseFilePdfDataUrl is not null)return;_reportLoading=true;try{var bytes=await Api.GetPurchaseFileSummaryPdfAsync(Id);_purchaseFilePdfDataUrl=$"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";}catch(Exception ex){Snackbar.Add("دریافت گزارش ناموفق بود: "+ex.Message,Severity.Error);}finally{_reportLoading=false;}}
    private async Task RunAi(string action){_aiBusy=true;try{await Api.RunAiAsync(Id,action);await LoadAi();Snackbar.Add("تحلیل تکمیل شد.",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}finally{_aiBusy=false;}}
    private async Task EvaluateTenderLegalRules(){_aiBusy=true;try{var result=await Api.EvaluatePurchaseFileLegalRulesAsync(Id);var fail=result.Findings.Count(x=>x.Result==RuleResult.Fail);var warning=result.Findings.Count(x=>x.Result==RuleResult.Warning||x.Result==RuleResult.NeedHumanReview);Snackbar.Add($"بررسی قوانین مناقصه انجام شد. خطا: {fail}، هشدار/نیازمند بررسی: {warning}",Severity.Success);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}finally{_aiBusy=false;}}
    private string DepartmentName(Guid id)=>Access.Departments.FirstOrDefault(x=>x.Id==id)?.Title??FakeDirectory.DepartmentName(id);
    private static string FormatSize(long size)=>size<1024?$"{size} B":size<1048576?$"{size/1024d:0.#} KB":$"{size/1048576d:0.#} MB";
    private static string DocumentTypeText(DocumentType type)=>type switch{DocumentType.Indent=>"درخواست خرید",DocumentType.TechnicalSpecification=>"مشخصات فنی",DocumentType.CommercialOffer=>"پیشنهاد تجاری",DocumentType.Correspondence=>"مکاتبات",DocumentType.TenderDocument=>"اسناد مناقصه",DocumentType.TenderCommissionMinutes=>"صورتجلسه کمیسیون",DocumentType.Contract=>"قرارداد",DocumentType.PurchaseOrder=>"سفارش خرید",DocumentType.WarehouseReceipt=>"رسید انبار",DocumentType.FinalReport=>"گزارش نهایی",_=>type.ToString()};
    private static string AiType(string type)=>type switch{"Summary"=>"خلاصه پرونده","MissingDocuments"=>"بررسی نقص مدارک","Rules"=>"ارزیابی قوانین خرید",_=>type};
    private static Severity AiSeverity(PetroProcure.Contracts.V1.Ai.AiSeverity s)=>s>=PetroProcure.Contracts.V1.Ai.AiSeverity.High?Severity.Error:s>=PetroProcure.Contracts.V1.Ai.AiSeverity.Medium?Severity.Warning:Severity.Info;
}
