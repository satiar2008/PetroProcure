@page "/admin/procurement-rules/test"
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar
@inject IUserAccessContext Access
@inject NavigationManager Nav

<PageHeader Title="آزمون قوانین مناقصه" Subtitle="اجرای آزمایشی Rule Engine قطعی روی پرونده خرید؛ نتیجه فقط پیشنهاد و هشدار است." />

<MudAlert Severity="Severity.Warning" Class="mb-4">
    AI و Rule Engine تصمیم نهایی تجاری یا حقوقی نمی‌گیرند؛ نتیجه فقط برای کمک به کارشناس، کمیسیون و مدیران است.
</MudAlert>

<MudPaper Class="pa-4 mb-4" Elevation="0">
    <MudTextField @bind-Value="_purchaseFileId" Label="کد داخلی پرونده خرید" HelperText="از مسیر جزئیات پرونده خرید قابل دریافت است." />
    <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy" OnClick="EvaluateAsync">اجرای ارزیابی</MudButton>
</MudPaper>

@if (_evaluation is not null)
{
    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6">@_evaluation.Summary</MudText>
        <MudText Typo="Typo.caption">زمان ارزیابی: <DateDisplay Value="@_evaluation.EvaluatedAt" /></MudText>
        @foreach (var finding in _evaluation.Findings)
        {
            <MudAlert Severity="@FindingSeverity(finding)" Variant="Variant.Outlined" Class="my-2">
                <strong>@finding.Title</strong>
                <br />
                @finding.Description
                <br />
                <MudText Typo="Typo.caption">ارجاع قانونی: @finding.LegalReference</MudText>
            </MudAlert>
        }
    </MudPaper>
}

@code {
    private string _purchaseFileId = "";
    private bool _busy;
    private ProcurementRuleEvaluationDto? _evaluation;

    protected override void OnInitialized()
    {
        if (!Access.HasPermission("ProcurementRule.Evaluate") && !Access.HasPermission("AiAgent.EvaluatePurchaseRules"))
        {
            Nav.NavigateTo("/access-denied");
        }
    }

    private async Task EvaluateAsync()
    {
        if (!Guid.TryParse(_purchaseFileId, out var id))
        {
            Snackbar.Add("کد داخلی پرونده خرید معتبر نیست.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            _evaluation = await Api.EvaluatePurchaseFileLegalRulesAsync(id);
            Snackbar.Add("ارزیابی قوانین مناقصه انجام شد.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(UiErrorText.From(ex), Severity.Error); }
        finally { _busy = false; }
    }

    private static Severity FindingSeverity(ProcurementRuleFindingDto finding) => finding.Result switch
    {
        RuleResult.Fail => Severity.Error,
        RuleResult.Warning => Severity.Warning,
        RuleResult.NeedHumanReview => Severity.Info,
        _ => finding.Severity >= RuleSeverity.Critical ? Severity.Error : Severity.Info
    };
}
