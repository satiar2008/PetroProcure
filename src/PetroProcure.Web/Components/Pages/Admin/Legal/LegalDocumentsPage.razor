@page "/admin/legal-documents"
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject IJSRuntime JS

<PageHeader Title="اسناد قانونی مناقصات" Subtitle="بارگذاری و ساختاردهی قوانین برگزاری مناقصات" />

<MudGrid Class="mb-4">
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6">بارگذاری سند قانونی</MudText>
            <MudTextField @bind-Value="_title" Label="عنوان سند" Required="true" Class="mt-3" />
            <MudTextField @bind-Value="_sourceTitle" Label="عنوان منبع" />
            <MudTextField @bind-Value="_sourceNumber" Label="شماره/شناسه منبع" />
            <MudDatePicker @bind-Date="_sourceDate" Label="تاریخ منبع" />
            <MudTextField @bind-Value="_description" Label="توضیحات" Lines="2" />
            <InputFile OnChange="OnFileSelected" class="mt-3" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">@(_file?.Name ?? "فایلی انتخاب نشده است")</MudText>
            <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy" OnClick="UploadAsync">بارگذاری</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6">جستجو</MudText>
            <MudTextField @bind-Value="_search" Label="عنوان یا نام فایل" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
            <MudButton Variant="Variant.Outlined" OnClick="LoadAsync">اعمال فیلتر</MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_loading)
{
    <LoadingOverlay IsVisible="true" Text="در حال دریافت اسناد..." />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
    <MudButton Class="mt-2" OnClick="LoadAsync">تلاش مجدد</MudButton>
}
else if (_documents.Count == 0)
{
    <EmptyState Title="سندی ثبت نشده است" Description="PDF قوانین مناقصات را بارگذاری کنید و سپس مواد و بندها را بسازید." />
}
else
{
    <MudTable Items="_documents" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>عنوان</MudTh>
            <MudTh>فایل</MudTh>
            <MudTh>منبع</MudTh>
            <MudTh>حجم</MudTh>
            <MudTh>وضعیت</MudTh>
            <MudTh>هش</MudTh>
            <MudTh>تاریخ بارگذاری</MudTh>
            <MudTh>عملیات</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Title</MudTd>
            <MudTd>@context.OriginalFileName</MudTd>
            <MudTd>@(context.SourceDocumentTitle ?? context.SourceDocumentNumber ?? "-")</MudTd>
            <MudTd>@FormatSize(context.Size)</MudTd>
            <MudTd><StatusChip Text="@StatusText(context.Status)" /></MudTd>
            <MudTd><MudText Typo="Typo.caption">@context.FileHash[..Math.Min(12, context.FileHash.Length)]...</MudText></MudTd>
            <MudTd><DateDisplay Value="@context.UploadedAt" /></MudTd>
            <MudTd>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo($"/admin/legal-documents/{context.Id}"))">جزئیات</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Download" OnClick="@(() => DownloadAsync(context.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private readonly List<LegalDocumentDto> _documents = [];
    private string? _search;
    private string _title = "قوانین برگزاری مناقصات";
    private string? _sourceTitle;
    private string? _sourceNumber;
    private DateTime? _sourceDate;
    private string? _description;
    private IBrowserFile? _file;
    private bool _loading;
    private bool _busy;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            var result = await Api.GetLegalDocumentsAsync(new LegalDocumentListRequest(_search, PageSize: 50));
            _documents.Clear();
            _documents.AddRange(result.Items);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void OnFileSelected(InputFileChangeEventArgs e) => _file = e.File;

    private async Task UploadAsync()
    {
        if (_file is null || string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("عنوان و فایل سند الزامی است.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await using var stream = _file.OpenReadStream(50 * 1024 * 1024);
            await Api.UploadLegalDocumentAsync(stream, _file.Name, _file.ContentType, _title, _description,
                _sourceTitle, _sourceNumber, _sourceDate);
            Snackbar.Add("سند قانونی بارگذاری شد.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DownloadAsync(Guid id)
    {
        try
        {
            var file = await Api.DownloadLegalDocumentAsync(id);
            await JS.InvokeVoidAsync("petroProcureDownloadFile", file.Content, file.ContentType, file.FileName);
        }
        catch (Exception ex) { Snackbar.Add("دانلود سند ناموفق بود: " + ex.Message, Severity.Error); }
    }

    private async Task DeleteAsync(Guid id)
    {
        var dialog = await Dialog.ShowAsync<ConfirmDialog>("حذف سند قانونی",
            new DialogParameters { { "Message", "سند به صورت نرم حذف شود؟ فایل فیزیکی فعلاً برای audit باقی می‌ماند." }, { "ConfirmColor", Color.Error } });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        try
        {
            await Api.DeleteLegalDocumentAsync(id);
            Snackbar.Add("سند قانونی حذف شد.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private static string FormatSize(long size) => size <= 0 ? "-" :
        size < 1024 ? $"{size} B" :
        size < 1024 * 1024 ? $"{size / 1024d:0.#} KB" : $"{size / 1024d / 1024d:0.#} MB";

    private static string StatusText(LegalDocumentStatus status) => status switch
    {
        LegalDocumentStatus.Draft => "پیش‌نویس",
        LegalDocumentStatus.PendingApproval => "در انتظار تأیید",
        LegalDocumentStatus.Active => "فعال",
        LegalDocumentStatus.Deprecated => "منسوخ",
        LegalDocumentStatus.Archived => "بایگانی",
        _ => status.ToString()
    };
}
