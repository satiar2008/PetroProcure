@page "/admin/departments"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
<PageTitle>واحدهای سازمانی</PageTitle>
<PageHeader Title="واحدهای سازمانی" Subtitle="مشاهده، تغییر نام نمایشی و مشاهده کاربران هر واحد" />
@if (_loading) { <LoadingOverlay Visible="true" /> }
else if (_error is not null) { <EmptyState Title="دریافت واحدها ناموفق بود" Description="@_error"><Action><MudButton OnClick="Load">تلاش مجدد</MudButton></Action></EmptyState> }
else
{
    <MudPaper Class="data-panel" Elevation="0">
        <MudTable Items="_departments" Dense="true" Hover="true">
            <HeaderContent><MudTh>نام واحد</MudTh><MudTh>نوع</MudTh><MudTh>وضعیت</MudTh><MudTh>کاربران</MudTh><MudTh>عملیات</MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Type</MudTd>
                <MudTd><StatusChip Text="@(context.IsActive ? "فعال" : "غیرفعال")" Color="@(context.IsActive ? Color.Success : Color.Default)" /></MudTd>
                <MudTd>@_users.Count(user => user.DepartmentIds.Contains(context.Id))</MudTd>
                <MudTd><MudButton Size="Size.Small" OnClick="@(() => BeginEdit(context))">ویرایش نام</MudButton></MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
    @if (_selectedDepartment is not null)
    {
        <MudPaper Class="form-panel mt-4" Elevation="0">
            <MudText Typo="Typo.h6">ویرایش واحد @_selectedDepartment.Type</MudText>
            <MudTextField @bind-Value="_departmentName" Label="نام نمایشی" Required="true" />
            <MudText Typo="Typo.subtitle2" Class="mt-3">کاربران این واحد</MudText>
            <MudChipSet T="string">
                @foreach (var user in _users.Where(user => user.DepartmentIds.Contains(_selectedDepartment.Id)))
                {
                    <MudChip Text="@(user.DisplayName ?? user.UserName)" />
                }
            </MudChipSet>
            <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDepartment">ذخیره</MudButton>
            <MudButton Class="mt-3" Variant="Variant.Text" OnClick="@(() => _selectedDepartment = null)">انصراف</MudButton>
        </MudPaper>
    }
}
@code {
    private List<DepartmentDto> _departments = [];
    private List<UserDto> _users = [];
    private DepartmentDto? _selectedDepartment;
    private bool _loading = true;
    private string? _error, _departmentName;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!AdminUiPolicy.CanManageDepartments(Access.HasPermission)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load(); StateHasChanged();
    }
    private async Task Load()
    {
        _loading = true; _error = null;
        try { var departments = Api.GetDepartmentsAsync(); var users = Api.GetUsersAsync(); await Task.WhenAll(departments, users); _departments = await departments; _users = await users; }
        catch (Exception ex) { _error = "امکان دریافت واحدها وجود ندارد."; Snackbar.Add(ex.Message, Severity.Error); }
        finally { _loading = false; }
    }
    private void BeginEdit(DepartmentDto department) { _selectedDepartment = department; _departmentName = department.Name; }
    private async Task SaveDepartment()
    {
        if (_selectedDepartment is null || string.IsNullOrWhiteSpace(_departmentName)) return;
        try { await Api.UpdateDepartmentAsync(_selectedDepartment.Id, new(_departmentName)); Snackbar.Add("واحد ذخیره شد.", Severity.Success); _selectedDepartment = null; await Load(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
}
