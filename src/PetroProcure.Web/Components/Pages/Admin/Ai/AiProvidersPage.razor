@page "/admin/ai/providers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar

<PageHeader Title="ارائه‌دهندگان هوش مصنوعی" Subtitle="تنظیم اتصال AiCore بدون ذخیره‌سازی کلید محرمانه در پایگاه داده" />

<DataStateView TItem="AiProviderDto" Loading="_loading" Error="@_error" Items="_providers" OnRetry="LoadAsync">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.h6">وضعیت provider</MudText>
                @foreach (var provider in _providers)
                {
                    <MudList T="string" Dense="true">
                        <MudListItem Text="@provider.Name" Icon="@Icons.Material.Filled.Psychology" />
                        <MudListItem Text="@($"مدل پیش‌فرض: {provider.DefaultModel ?? "—"}")" />
                        <MudListItem Text="@($"وضعیت: {(provider.IsEnabled ? "فعال" : "غیرفعال")}")" />
                        <MudListItem Text="@($"BaseUrl: {provider.BaseUrl ?? "ثبت نشده"}")" />
                    </MudList>
                }
                @if (_health is not null)
                {
                    <MudAlert Severity="@(_health.IsHealthy ? Severity.Success : Severity.Warning)" Dense="true" Class="mt-3">
                        @_health.Status
                        @if (!string.IsNullOrWhiteSpace(_health.ErrorMessage))
                        {
                            <div>@_health.ErrorMessage</div>
                        }
                    </MudAlert>
                }
                <MudButton Class="mt-3" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.NetworkCheck"
                           Disabled="_testing" OnClick="TestAsync">
                    تست اتصال
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Outlined="true">
                <MudForm @ref="_form">
                    <MudSwitch T="bool" @bind-Value="_enabled" Color="Color.Primary" Label="فعال باشد" />
                    <MudTextField @bind-Value="_baseUrl" Label="آدرس AiCore" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_analysisPath" Label="مسیر تحلیل" Variant="Variant.Outlined"
                                  HelperText="برای AI Server Core: /api/ai/text" />
                    <MudTextField @bind-Value="_healthPath" Label="مسیر Health" Variant="Variant.Outlined"
                                  HelperText="برای تست اتصال عمومی AI Server Core: /health/ready" />
                    <MudTextField @bind-Value="_defaultModel" Label="مدل پیش‌فرض" Variant="Variant.Outlined" />
                    <MudNumericField T="int" @bind-Value="_timeoutSeconds" Label="Timeout ثانیه" Variant="Variant.Outlined" Min="5" Max="300" />
                    <MudNumericField T="int?" @bind-Value="_maxInputTokens" Label="حداکثر توکن ورودی" Variant="Variant.Outlined" />
                    <MudNumericField T="int?" @bind-Value="_maxOutputTokens" Label="حداکثر توکن خروجی" Variant="Variant.Outlined" />
                    <MudSwitch T="bool" @bind-Value="_useStreaming" Color="Color.Secondary" Label="Streaming فعال شود" Disabled="true" />
                    <MudTextField @bind-Value="_tenant" Label="Tenant" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_clientId" Label="ClientId" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_apiKeySecretName" Label="نام secret / متغیر محیطی کلید API" Variant="Variant.Outlined"
                                  HelperText="بهتر است فقط نام secret مانند PETROPROCURE_AICORE_API_KEY ثبت شود. اگر قبلاً کلید خام aic_ اینجا ذخیره شده باشد، فعلاً برای سازگاری خوانده می‌شود ولی باید به env/user-secrets منتقل شود." />
                    <MudAlert Severity="@(_hasApiKey ? Severity.Success : Severity.Warning)" Dense="true" Class="mt-2">
                        @(_hasApiKey ? "کلید محرمانه از منبع امن قابل خواندن است." : "کلید محرمانه تنظیم نشده یا قابل خواندن نیست.")
                    </MudAlert>
                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="_saving" OnClick="SaveAsync">
                            ذخیره تنظیمات
                        </MudButton>
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">
                            بارگذاری مجدد
                        </MudButton>
                    </MudStack>
                </MudForm>
            </MudPaper>
        </MudItem>
    </MudGrid>
</DataStateView>

@code {
    private MudForm? _form;
    private List<AiProviderDto> _providers = [];
    private AiProviderHealthDto? _health;
    private bool _loading;
    private bool _saving;
    private bool _testing;
    private string? _error;

    private string? _baseUrl;
    private string? _defaultModel;
    private int _timeoutSeconds = 60;
    private int? _maxInputTokens;
    private int? _maxOutputTokens;
    private bool _enabled;
    private bool _useStreaming;
    private string? _tenant;
    private string? _clientId;
    private string? _apiKeySecretName;
    private string _analysisPath = "/api/ai/text";
    private string _healthPath = "/health/ready";
    private bool _hasApiKey;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _providers = await Api.GetAiProvidersAsync();
            var settings = await Api.GetAiCoreSettingsAsync();
            _baseUrl = settings.BaseUrl;
            _defaultModel = settings.DefaultModel;
            _timeoutSeconds = settings.TimeoutSeconds;
            _maxInputTokens = settings.MaxInputTokens;
            _maxOutputTokens = settings.MaxOutputTokens;
            _enabled = settings.IsEnabled;
            _useStreaming = settings.UseStreaming;
            _tenant = settings.Tenant;
            _clientId = settings.ClientId;
            _apiKeySecretName = settings.ApiKeySecretName;
            _analysisPath = string.IsNullOrWhiteSpace(settings.AnalysisPath) ? "/api/ai/text" : settings.AnalysisPath;
            _healthPath = string.IsNullOrWhiteSpace(settings.HealthPath) ? "/health/ready" : settings.HealthPath;
            _hasApiKey = settings.HasApiKey;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            await Api.UpdateAiCoreSettingsAsync(new ConfigureAiCoreProviderRequest(_baseUrl, _defaultModel,
                _timeoutSeconds, _maxInputTokens, _maxOutputTokens, _enabled, false, _tenant, _clientId,
                _apiKeySecretName, _analysisPath, _healthPath));
            Snackbar.Add("تنظیمات AiCore ذخیره شد.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"ذخیره تنظیمات ناموفق بود: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task TestAsync()
    {
        _testing = true;
        try
        {
            _health = await Api.TestAiCoreAsync();
            Snackbar.Add(_health.IsHealthy ? "ارتباط با AiCore برقرار است." : "ارتباط با AiCore تأیید نشد.", _health.IsHealthy ? Severity.Success : Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تست اتصال ناموفق بود: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testing = false;
        }
    }
}
