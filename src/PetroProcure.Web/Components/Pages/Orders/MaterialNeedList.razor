@page "/orders/material-needs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IUserAccessContext Access

<PageHeader Title="نیازهای کالا" Subtitle="ثبت، بررسی، تأیید و تبدیل نیازهای کالا به تقاضای خرید">
    <Actions>
        @if (Access.HasPermission(OrdersUiPolicy.CreateMaterialNeed))
        {
            <MudButton Href="/orders/material-needs/create" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">ثبت نیاز جدید</MudButton>
        }
        @if (Access.HasPermission(OrdersUiPolicy.ConvertNeedToIndent) && _selectedNeedIds.Count > 0)
        {
            <MudButton Color="Color.Secondary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.MergeType" OnClick="ConvertSelected">
                تجمیع انتخاب‌ها در Indent
            </MudButton>
        }
    </Actions>
</PageHeader>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="3"><MudSelect T="MaterialNeedStatus?" @bind-Value="_status" Label="وضعیت" Clearable="true" Variant="Variant.Outlined">@foreach (var s in Enum.GetValues<MaterialNeedStatus>()) { <MudSelectItem T="MaterialNeedStatus?" Value="@s">@OrdersUiPolicy.StatusText(s)</MudSelectItem> }</MudSelect></MudItem>
        <MudItem xs="12" md="3"><MudSelect T="MaterialNeedPriority?" @bind-Value="_priority" Label="اولویت" Clearable="true" Variant="Variant.Outlined">@foreach (var p in Enum.GetValues<MaterialNeedPriority>()) { <MudSelectItem T="MaterialNeedPriority?" Value="@p">@OrdersUiPolicy.PriorityText(p)</MudSelectItem> }</MudSelect></MudItem>
        <MudItem xs="12" md="4"><MudTextField @bind-Value="_mescCode" Label="کد MESC" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2"><MudButton OnClick="Load" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary">اعمال فیلتر</MudButton></MudItem>
    </MudGrid>
</MudPaper>

@if (!_loading && Access.HasPermission(OrdersUiPolicy.ConvertNeedToIndent) && _suggestedGroups.Count > 0)
{
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">پیشنهاد خودکار تجمیع نیازها</MudText>
        <MudGrid>
            @foreach (var group in _suggestedGroups)
            {
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.subtitle2">@group.MescGeneralGroupCode - @group.GeneralDescription</MudText>
                        <MudText Typo="Typo.body2">@group.Items.Count نیاز تأییدشده، مجموع مقدار @group.Items.Sum(x => x.RequestedQuantity).ToString("N2")</MudText>
                        <MudText Typo="Typo.caption">@string.Join("، ", group.Items.Select(x => x.NeedNumber))</MudText>
                        <MudButton Class="mt-2" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                   OnClick="@(()=>ConvertGroup(group))">ایجاد Indent تجمیعی</MudButton>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>
}

@if (_loading) { <LoadingOverlay Text="در حال دریافت نیازها..." /> }
else
{
    <MudTable Items="_needs" Dense="true" Hover="true">
        <HeaderContent><MudTh></MudTh><MudTh>شماره نیاز</MudTh><MudTh>کد MESC</MudTh><MudTh>شرح کالا</MudTh><MudTh>مقدار</MudTh><MudTh>اولویت</MudTh><MudTh>وضعیت</MudTh><MudTh>عملیات</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>
                @if (Access.HasPermission(OrdersUiPolicy.ConvertNeedToIndent) && context.Status == MaterialNeedStatus.Approved)
                {
                    <MudCheckBox T="bool" Value="@IsSelected(context.Id)" ValueChanged="@((bool value)=>ToggleSelected(context, value))" />
                }
            </MudTd>
            <MudTd><MudLink Href="@($"/orders/material-needs/{context.Id}")">@context.NeedNumber</MudLink></MudTd>
            <MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.RequestedQuantity</MudTd>
            <MudTd>@OrdersUiPolicy.PriorityText(context.Priority)</MudTd><MudTd>@OrdersUiPolicy.StatusText(context.Status)</MudTd>
            <MudTd>
                <MudButton Size="Size.Small" OnClick="@(()=>Nav.NavigateTo($"/orders/material-needs/{context.Id}"))">مشاهده</MudButton>
                @if (context.Status == MaterialNeedStatus.Draft)
                {
                    <MudButton Size="Size.Small" Color="Color.Info" OnClick="@(()=>Submit(context.Id))">ارسال</MudButton>
                }
                @if (Access.HasPermission(OrdersUiPolicy.ApproveMaterialNeed) && context.Status is MaterialNeedStatus.Submitted or MaterialNeedStatus.UnderReview)
                {
                    <MudButton Size="Size.Small" Color="Color.Success" OnClick="@(()=>Approve(context.Id))">تأیید</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(()=>Reject(context.Id))">رد</MudButton>
                }
                @if (Access.HasPermission(OrdersUiPolicy.ConvertNeedToIndent) && context.Status == MaterialNeedStatus.Approved)
                {
                    <MudButton Size="Size.Small" Color="Color.Primary" OnClick="@(()=>Convert(context.Id))">تبدیل به Indent</MudButton>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><EmptyState Title="نیاز کالایی یافت نشد" /></NoRecordsContent>
    </MudTable>
}

@code {
    private List<MaterialNeedDto> _needs = [];
    private List<MaterialNeedsGroupedByMescDto> _suggestedGroups = [];
    private readonly HashSet<Guid> _selectedNeedIds = [];
    private bool _loading = true;
    private MaterialNeedStatus? _status;
    private MaterialNeedPriority? _priority;
    private string? _mescCode;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load()
    {
        _loading = true;
        try
        {
            var request = new MaterialNeedListRequest(_status, _priority, _mescCode, null, null, null, 1, 100);
            _needs = (await Api.GetMaterialNeedsAsync(request)).Items.ToList();
            _suggestedGroups = (await Api.GetMaterialNeedsGroupedByMescAsync(new MaterialNeedListRequest(MaterialNeedStatus.Approved, null, _mescCode, null, null, null, 1, 100)))
                .Where(x => x.Items.Count > 1)
                .ToList();
            _selectedNeedIds.RemoveWhere(id => _needs.All(x => x.Id != id || x.Status != MaterialNeedStatus.Approved));
        }
        catch (Exception ex) { Snackbar.Add($"دریافت نیازها ناموفق بود: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }
    private async Task Submit(Guid id) => await Run(async () => await Api.ChangeMaterialNeedStatusAsync(id, "submit"), "نیاز ارسال شد.");
    private async Task Approve(Guid id) => await Run(async () => await Api.ChangeMaterialNeedStatusAsync(id, "approve", new ApproveMaterialNeedRequest()), "نیاز تأیید شد.");
    private async Task Reject(Guid id) => await Run(async () => await Api.ChangeMaterialNeedStatusAsync(id, "reject", new RejectMaterialNeedRequest("رد توسط کاربر")), "نیاز رد شد.");
    private async Task Convert(Guid id)
    {
        var indentId = await Api.ConvertMaterialNeedToIndentAsync(id, new ConvertMaterialNeedToIndentRequest(DateTime.UtcNow.Year % 100, 3));
        Snackbar.Add("نیاز به تقاضای خرید تبدیل شد.", Severity.Success);
        Nav.NavigateTo($"/orders/indents/{indentId}");
    }
    private bool IsSelected(Guid id) => _selectedNeedIds.Contains(id);
    private void ToggleSelected(MaterialNeedDto need, bool selected)
    {
        if (selected)
        {
            var selectedGroups = _needs.Where(x => _selectedNeedIds.Contains(x.Id)).Select(x => x.MescGeneralGroupCode)
                .Distinct(StringComparer.OrdinalIgnoreCase).ToArray();
            if (selectedGroups.Length > 0 && selectedGroups.All(x => !string.Equals(x, need.MescGeneralGroupCode, StringComparison.OrdinalIgnoreCase)))
            {
                Snackbar.Add("برای تجمیع، همه نیازهای انتخابی باید از یک گروه کالا باشند.", Severity.Warning);
                return;
            }
            _selectedNeedIds.Add(need.Id);
        }
        else _selectedNeedIds.Remove(need.Id);
    }
    private async Task ConvertSelected()
    {
        var selected = _needs.Where(x => _selectedNeedIds.Contains(x.Id)).ToArray();
        if (selected.Length == 0) return;
        if (selected.Select(x => x.MescGeneralGroupCode).Distinct(StringComparer.OrdinalIgnoreCase).Count() > 1)
        {
            Snackbar.Add("نیازهای انتخاب‌شده از یک گروه کالا نیستند.", Severity.Warning);
            return;
        }
        await ConvertMany(selected.Select(x => x.Id).ToArray(), $"تقاضای تجمیعی گروه {selected[0].MescGeneralGroupCode}");
    }
    private async Task ConvertGroup(MaterialNeedsGroupedByMescDto group) =>
        await ConvertMany(group.Items.Select(x => x.Id).ToArray(), $"تقاضای تجمیعی گروه {group.MescGeneralGroupCode}");
    private async Task ConvertMany(IReadOnlyList<Guid> ids, string title)
    {
        try
        {
            var indentId = await Api.ConvertMaterialNeedsToIndentAsync(new ConvertMaterialNeedsToIndentRequest(ids, DateTime.UtcNow.Year % 100, 3, title));
            Snackbar.Add("نیازهای کالا در یک Indent تجمیع شدند.", Severity.Success);
            _selectedNeedIds.Clear();
            Nav.NavigateTo($"/orders/indents/{indentId}");
        }
        catch (Exception ex) { Snackbar.Add($"تجمیع ناموفق بود: {ex.Message}", Severity.Error); }
    }
    private async Task Run(Func<Task> action, string success)
    {
        try { await action(); Snackbar.Add(success, Severity.Success); await Load(); }
        catch (Exception ex) { Snackbar.Add($"عملیات ناموفق بود: {ex.Message}", Severity.Error); }
    }
}
