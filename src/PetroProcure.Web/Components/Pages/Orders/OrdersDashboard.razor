@page "/orders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar

<PageHeader Title="داشبورد سفارشات و کنترل موجودی" Subtitle="نمای کلی نیازهای کالا، کمبودها و وضعیت تقاضاهای خرید" />

@if (_loading)
{
    <LoadingOverlay Text="در حال دریافت داشبورد..." />
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
    <MudButton OnClick="Load" StartIcon="@Icons.Material.Filled.Refresh">تلاش مجدد</MudButton>
}
else if (_dashboard is not null)
{
    <MudGrid>
        <MudItem xs="12" md="2"><MudPaper Class="pa-4"><MudText Typo="Typo.h5">@_dashboard.OpenMaterialNeeds</MudText><MudText>نیازهای باز</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="2"><MudPaper Class="pa-4"><MudText Typo="Typo.h5">@_dashboard.ApprovedNeedsWaitingForIndent</MudText><MudText>آماده تبدیل به Indent</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="2"><MudPaper Class="pa-4"><MudText Typo="Typo.h5">@_dashboard.OpenShortageAlerts</MudText><MudText>هشدار کمبود باز</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="3"><MudPaper Class="pa-4"><MudText Typo="Typo.h5">@_dashboard.IndentsWaitingForApproval</MudText><MudText>تقاضاهای منتظر تأیید</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="3"><MudPaper Class="pa-4"><MudText Typo="Typo.h5">@_dashboard.IndentsSentToPurchaseDepartment</MudText><MudText>ارسال‌شده به خرید</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudGrid Class="mt-4">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6">اقلام بحرانی</MudText>
                <MudTable Items="_dashboard.CriticalItems" Dense="true">
                    <HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>موجودی</MudTh><MudTh>نقطه سفارش</MudTh></HeaderContent>
                    <RowTemplate><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.CurrentStock</MudTd><MudTd>@context.ReorderPoint</MudTd></RowTemplate>
                    <NoRecordsContent><EmptyState Title="قلم بحرانی وجود ندارد" /></NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6">آخرین نیازهای کالا</MudText>
                <MudTable Items="_dashboard.RecentMaterialNeeds" Dense="true">
                    <HeaderContent><MudTh>شماره</MudTh><MudTh>کالا</MudTh><MudTh>وضعیت</MudTh></HeaderContent>
                    <RowTemplate><MudTd><MudLink Href="@($"/orders/material-needs/{context.Id}")">@context.NeedNumber</MudLink></MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@OrdersUiPolicy.StatusText(context.Status)</MudTd></RowTemplate>
                    <NoRecordsContent><EmptyState Title="نیازی ثبت نشده است" /></NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private OrdersDashboardDto? _dashboard;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load()
    {
        _loading = true; _error = null;
        try { _dashboard = await Api.GetOrdersDashboardAsync(); }
        catch (Exception ex) { _error = $"دریافت داشبورد ناموفق بود: {ex.Message}"; Snackbar.Add(_error, Severity.Error); }
        finally { _loading = false; }
    }
}
