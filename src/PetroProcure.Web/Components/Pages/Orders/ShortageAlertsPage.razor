@page "/orders/shortage-alerts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IUserAccessContext Access

<PageHeader Title="هشدارهای کمبود" Subtitle="تشخیص کمبود بر اساس موجودی برنامه‌ریزی و نقطه سفارش">
    <Actions>
        @if (Access.HasPermission(OrdersUiPolicy.ManageShortageAlerts))
        {
            <MudButton Color="Color.Warning" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Search" OnClick="Detect">تشخیص کمبودها</MudButton>
        }
    </Actions>
</PageHeader>

@if (_loading) { <LoadingOverlay Text="در حال دریافت هشدارها..." /> }
else
{
    <MudTable Items="_alerts" Dense="true" Hover="true" GroupBy="_groupDefinition">
        <HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>موجودی</MudTh><MudTh>نقطه سفارش</MudTh><MudTh>کمبود</MudTh><MudTh>وضعیت</MudTh><MudTh>تقاضای مرتبط</MudTh><MudTh>عملیات</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.CurrentStock</MudTd><MudTd>@context.ReorderPoint</MudTd><MudTd>@context.ShortageQuantity</MudTd>
            <MudTd>@OrdersUiPolicy.AlertStatusText(context.Status)</MudTd>
            <MudTd>@if(context.RelatedIndentId.HasValue){<MudLink Href="@($"/orders/indents/{context.RelatedIndentId}")">مشاهده Indent</MudLink>}else{<span>—</span>}</MudTd>
            <MudTd>
                @if (Access.HasPermission(OrdersUiPolicy.ConvertShortageToIndent) && context.Status is ShortageAlertStatus.Open or ShortageAlertStatus.InProgress)
                {
                    <MudButton Size="Size.Small" Color="Color.Primary" OnClick="@(()=>Convert(context.Id))">تبدیل به Indent</MudButton>
                }
                @if (Access.HasPermission(OrdersUiPolicy.ManageShortageAlerts) && context.Status is ShortageAlertStatus.Open or ShortageAlertStatus.InProgress)
                {
                    <MudButton Size="Size.Small" OnClick="@(()=>Resolve(context.Id))">رفع شد</MudButton>
                }
            </MudTd>
        </RowTemplate>
        <GroupHeaderTemplate>
            <MudTh colspan="8">@context.Key</MudTh>
        </GroupHeaderTemplate>
        <NoRecordsContent><EmptyState Title="هشدار کمبود وجود ندارد" /></NoRecordsContent>
    </MudTable>
}

@code {
    private List<ShortageAlertDto> _alerts = [];
    private bool _loading = true;
    private TableGroupDefinition<ShortageAlertDto> _groupDefinition = new()
    {
        GroupName = "گروه MESC",
        Selector = x => $"{x.MescGeneralGroupCode} - {x.GeneralDescription}"
    };

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load()
    {
        _loading = true;
        try { _alerts = (await Api.GetShortageAlertsAsync(new ShortageAlertListRequest(null, null, 1, 100))).Items.ToList(); }
        catch (Exception ex) { Snackbar.Add($"دریافت هشدارها ناموفق بود: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }
    private async Task Detect()
    {
        try { var created = await Api.DetectShortagesAsync(new DetectShortageAlertsRequest()); Snackbar.Add($"{created.Count} هشدار جدید ایجاد شد.", Severity.Success); await Load(); }
        catch (Exception ex) { Snackbar.Add($"تشخیص کمبود ناموفق بود: {ex.Message}", Severity.Error); }
    }
    private async Task Convert(Guid id)
    {
        try
        {
            var indentId = await Api.ConvertShortageToIndentAsync(id, new ConvertShortageToIndentRequest(DateTime.UtcNow.Year % 100, 3, Access.CurrentDepartment.Id));
            Snackbar.Add("هشدار به تقاضای خرید تبدیل شد.", Severity.Success);
            Nav.NavigateTo($"/orders/indents/{indentId}");
        }
        catch (Exception ex) { Snackbar.Add($"تبدیل ناموفق بود: {ex.Message}", Severity.Error); }
    }
    private async Task Resolve(Guid id)
    {
        try { await Api.ResolveShortageAlertAsync(id, new ResolveShortageAlertRequest("رفع‌شده از پنل کنترل موجودی")); }
        catch (Exception ex) { Snackbar.Add($"رفع هشدار ناموفق بود: {ex.Message}", Severity.Error); return; }
        Snackbar.Add("هشدار رفع شد.", Severity.Success); await Load();
    }
}
