@page "/warehouse/receipts"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>رسیدهای انبار</PageTitle>

<PageHeader Title="رسیدهای انبار" Subtitle="فهرست دریافت‌های فیزیکی کالا در برابر سفارش‌های خرید">
    <Actions>
        <PermissionView Permission="@WarehouseUiPolicy.Create">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Href="/warehouse/purchase-orders-waiting">ثبت رسید از سفارش خرید</MudButton>
        </PermissionView>
    </Actions>
</PageHeader>

<MudPaper Class="filter-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="5"><MudTextField @bind-Value="_search" Label="جستجو در شماره رسید، سفارش، پرونده یا تأمین‌کننده" Variant="Variant.Outlined" Immediate="true" /></MudItem>
        <MudItem xs="12" md="3"><MudSelect T="WarehouseReceiptStatus?" @bind-Value="_status" Label="وضعیت" Variant="Variant.Outlined" Clearable="true">
            @foreach (var status in Enum.GetValues<WarehouseReceiptStatus>())
            { <MudSelectItem T="WarehouseReceiptStatus?" Value="@status">@WarehouseUiPolicy.ReceiptStatusText(status)</MudSelectItem> }
        </MudSelect></MudItem>
        <MudItem xs="12" md="2"><MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary" OnClick="Load">اعمال فیلتر</MudButton></MudItem>
        <MudItem xs="12" md="2"><MudButton FullWidth Variant="Variant.Outlined" OnClick="Clear">پاک‌سازی</MudButton></MudItem>
    </MudGrid>
</MudPaper>

@if (_loading) { <LoadingOverlay Visible="true" Text="در حال دریافت رسیدها..." /> }
else if (_error is not null) { <RetryPanel Message="@_error" OnRetry="Load" /> }
else if (_items.Count == 0) { <EmptyState Title="رسیدی ثبت نشده" Description="پس از دریافت کالا از سفارش خرید، رسیدها در این فهرست نمایش داده می‌شوند." /> }
else
{
    <MudTable Items="_items" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>شماره رسید</MudTh><MudTh>سفارش خرید</MudTh><MudTh>پرونده</MudTh><MudTh>انبار</MudTh><MudTh>تأمین‌کننده</MudTh><MudTh>وضعیت</MudTh><MudTh>تاریخ رسید</MudTh><MudTh>عملیات</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ReceiptNumber</MudTd>
            <MudTd>@context.PurchaseOrderNumber</MudTd>
            <MudTd>@context.PurchaseFileNumber</MudTd>
            <MudTd>@context.WarehouseName</MudTd>
            <MudTd>@context.SupplierName</MudTd>
            <MudTd><StatusChip Text="@WarehouseUiPolicy.ReceiptStatusText(context.Status)" Color="@WarehouseUiPolicy.ReceiptStatusColor(context.Status)" /></MudTd>
            <MudTd><DateDisplay Value="@context.ReceiptDate" /></MudTd>
            <MudTd><MudIconButton Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => Navigation.NavigateTo($"/warehouse/receipts/{context.Id}"))" /></MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<WarehouseReceiptSummaryDto> _items = [];
    private bool _loading = true;
    private string? _error, _search;
    private WarehouseReceiptStatus? _status;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Access.HasPermission(WarehouseUiPolicy.View)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        try { _items = (await Api.GetWarehouseReceiptsAsync(new(SearchTerm: _search, Status: _status, PageSize: 100))).Items.ToList(); }
        catch (Exception ex) { _error = ex.Message; Snackbar.Add("دریافت رسیدها ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _loading = false; }
    }

    private async Task Clear() { _search = null; _status = null; await Load(); }
}
