@page "/warehouse/stock-balances"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation

<PageTitle>موجودی کالا</PageTitle>
<PageHeader Title="موجودی کالا" Subtitle="موجودی قابل استفاده، رزروشده و در راه بر اساس انبار و کد MESC" />

<MudPaper Class="filter-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_search" Label="جستجو بر اساس کد یا شرح کالا" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary" OnClick="Load">جستجو</MudButton></MudItem>
    </MudGrid>
</MudPaper>

@if (_loading) { <LoadingOverlay Visible="true" Text="در حال دریافت موجودی..." /> }
else if (_error is not null) { <RetryPanel Message="@_error" OnRetry="Load" /> }
else if (_items.Count == 0) { <EmptyState Title="موجودی ثبت نشده" Description="پس از تأیید رسید انبار، موجودی کالا ایجاد یا به‌روزرسانی می‌شود." /> }
else
{
    <MudTable Items="_items" Dense="true" Hover="true">
        <HeaderContent><MudTh>کد MESC</MudTh><MudTh>گروه</MudTh><MudTh>شرح</MudTh><MudTh>انبار</MudTh><MudTh>قابل استفاده</MudTh><MudTh>رزرو</MudTh><MudTh>در راه</MudTh><MudTh>آخرین تغییر</MudTh></HeaderContent>
        <RowTemplate><MudTd>@context.MescCode</MudTd><MudTd>@context.MescGeneralGroupCode<br />@context.GeneralDescription</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@(context.WarehouseName ?? "—")</MudTd><MudTd>@context.AvailableQuantity</MudTd><MudTd>@context.ReservedQuantity</MudTd><MudTd>@context.OnOrderQuantity</MudTd><MudTd><DateDisplay Value="@context.LastUpdatedAt" IncludeTime="true" /></MudTd></RowTemplate>
    </MudTable>
}

@code {
    private List<PetroProcure.Contracts.V1.Warehouse.StockBalanceDto> _items = [];
    private bool _loading = true;
    private string? _error, _search;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Access.HasPermission(WarehouseUiPolicy.ViewStock)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        try { _items = (await Api.GetWarehouseStockBalancesAsync(new(SearchTerm: _search, PageSize: 100))).Items.ToList(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
