@page "/warehouse/receipts/{Id:guid}"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject IJSRuntime JS

<PageTitle>@(_detail?.Receipt.ReceiptNumber ?? "رسید انبار")</PageTitle>

@if (_loading) { <LoadingOverlay Visible="true" Text="در حال دریافت رسید انبار..." /> }
else if (_error is not null) { <RetryPanel Message="@_error" OnRetry="Load" /> }
else if (_detail is not null)
{
    <PageHeader Title="@_detail.Receipt.ReceiptNumber" Subtitle="@($"سفارش خرید: {_detail.Receipt.PurchaseOrderNumber}")">
        <Actions>
            <StatusChip Text="@WarehouseUiPolicy.ReceiptStatusText(_detail.Receipt.Status)" Color="@WarehouseUiPolicy.ReceiptStatusColor(_detail.Receipt.Status)" />
            <MudButton Variant="Variant.Outlined" Href="/warehouse/receipts">بازگشت</MudButton>
        </Actions>
    </PageHeader>

    <MudTabs Rounded="true" PanelClass="pa-4">
        <MudTabPanel Text="خلاصه" Icon="@Icons.Material.Filled.Info">@SummaryTab()</MudTabPanel>
        <MudTabPanel Text="اقلام" Icon="@Icons.Material.Filled.Inventory2">@ItemsTab()</MudTabPanel>
        <MudTabPanel Text="گردش موجودی" Icon="@Icons.Material.Filled.SyncAlt">@TransactionsTab()</MudTabPanel>
        <MudTabPanel Text="اسناد" Icon="@Icons.Material.Filled.AttachFile">@DocumentsTab()</MudTabPanel>
        <MudTabPanel Text="گزارش" Icon="@Icons.Material.Filled.PictureAsPdf">@ReportsTab()</MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private WarehouseReceiptDetailDto? _detail;
    private bool _loading = true, _busy, _uploading, _pdfLoading, _showPreview;
    private string? _error, _comment, _documentDescription, _pdfDataUrl;
    private string _documentType = "WarehouseReceiptAttachment";
    private long _maxUploadBytes = 50L * 1024 * 1024;

    private bool CanEdit => _detail is not null && WarehouseUiPolicy.IsEditable(_detail.Receipt.Status) && Access.HasPermission(WarehouseUiPolicy.Edit);
    private bool CanManageDocuments => Access.HasPermission(WarehouseUiPolicy.ManageDocuments);

    protected override async Task OnParametersSetAsync()
    {
        if (!Access.HasPermission(WarehouseUiPolicy.View)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        try
        {
            _detail = await Api.GetWarehouseReceiptAsync(Id) ?? throw new InvalidOperationException("رسید انبار یافت نشد.");
            try
            {
                var limits = await Api.GetUploadLimitsAsync();
                _maxUploadBytes = Math.Max(1, limits.MaxFileSizeMb) * 1024L * 1024L;
            }
            catch { _maxUploadBytes = 50L * 1024L * 1024L; }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private RenderFragment SummaryTab() => @<MudPaper Class="form-panel" Elevation="0">
        <div class="summary-grid">
            @Info("شماره رسید", _detail!.Receipt.ReceiptNumber)
            @Info("سفارش خرید", _detail.Receipt.PurchaseOrderNumber ?? "—")
            @Info("پرونده خرید", _detail.Receipt.PurchaseFileNumber ?? "—")
            @Info("انبار", _detail.Receipt.WarehouseName ?? "—")
            @Info("تأمین‌کننده", _detail.Receipt.SupplierName ?? "—")
            @Info("شماره حواله/بارنامه", _detail.Receipt.DeliveryNoteNumber ?? "—")
            @Info("حمل‌کننده", _detail.Receipt.CarrierName ?? "—")
            @Info("شماره خودرو", _detail.Receipt.VehicleNumber ?? "—")
            <div class="summary-item"><span>تاریخ رسید</span><strong><DateDisplay Value="@_detail.Receipt.ReceiptDate" /></strong></div>
            <div class="summary-item"><span>تاریخ ایجاد</span><strong><DateDisplay Value="@_detail.Receipt.CreatedAt" IncludeTime="true" /></strong></div>
        </div>
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle2">اقدامات وضعیت</MudText>
        <MudTextField @bind-Value="_comment" Label="توضیح اقدام" Lines="2" Variant="Variant.Outlined" Class="mt-3" />
        <div class="report-actions mt-3">
            @if (WarehouseUiPolicy.CanSubmit(_detail.Receipt.Status, Access.HasPermission))
            { <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy" OnClick="@(() => ChangeStatus("submit", new SubmitWarehouseReceiptRequest(_comment), "رسید ارسال شد."))">ارسال برای تأیید</MudButton> }
            @if (WarehouseUiPolicy.CanApprove(_detail.Receipt.Status, Access.HasPermission))
            { <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="_busy" OnClick="@(() => ChangeStatus("approve", new ApproveWarehouseReceiptRequest(_comment), "رسید تأیید و موجودی به‌روزرسانی شد."))">تأیید رسید</MudButton> }
            @if (WarehouseUiPolicy.CanCancel(_detail.Receipt.Status, Access.HasPermission))
            { <MudButton Color="Color.Error" Variant="Variant.Outlined" Disabled="_busy" OnClick="Cancel">لغو رسید</MudButton> }
        </div>
    </MudPaper>;

    private RenderFragment ItemsTab() => @<div>
        @if (_detail!.Items.Count == 0) { <EmptyState Title="قلمی در رسید ثبت نشده" Description="رسید پیش‌نویس باید حداقل یک قلم قابل دریافت داشته باشد." /> }
        @foreach (var group in _detail.Items.GroupBy(x => new { x.MescGeneralGroupCode, x.GeneralDescription }))
        {
            <MudPaper Class="item-group" Elevation="0">
                <div class="group-header"><div><strong>@group.Key.MescGeneralGroupCode</strong><span>@group.Key.GeneralDescription</span></div><MudChip T="string">@group.Count() قلم</MudChip></div>
                <MudTable Items="group" Dense="true">
                    <HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>سفارش</MudTh><MudTh>قبلاً دریافت</MudTh><MudTh>رسید</MudTh><MudTh>مانده بعد رسید</MudTh><MudTh>کیفیت</MudTh><MudTh></MudTh></HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.OrderedQuantity</MudTd><MudTd>@context.PreviouslyReceivedQuantity</MudTd><MudTd>@context.ReceivedQuantity</MudTd><MudTd>@context.RemainingQuantityAfterReceipt</MudTd><MudTd>@WarehouseUiPolicy.QualityText(context.QualityStatus)</MudTd>
                        <MudTd>@if (CanEdit) { <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => RemoveItem(context.Id))" /> }</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    </div>;

    private RenderFragment TransactionsTab() => @<div>
        @if (_detail!.InventoryTransactions.Count == 0) { <EmptyState Title="گردش موجودی ثبت نشده" Description="پس از تأیید رسید، تراکنش‌های موجودی ایجاد می‌شوند." /> }
        else
        {
            <MudTable Items="_detail.InventoryTransactions" Dense="true">
                <HeaderContent><MudTh>شماره گردش</MudTh><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>انبار</MudTh><MudTh>نوع</MudTh><MudTh>مقدار</MudTh><MudTh>تاریخ</MudTh></HeaderContent>
                <RowTemplate><MudTd>@context.TransactionNumber</MudTd><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.WarehouseName</MudTd><MudTd>@WarehouseUiPolicy.TransactionTypeText(context.TransactionType)</MudTd><MudTd>@context.Quantity</MudTd><MudTd><DateDisplay Value="@context.TransactionDate" /></MudTd></RowTemplate>
            </MudTable>
        }
    </div>;

    private RenderFragment DocumentsTab() => @<div>
        @if (CanManageDocuments)
        {
            <MudPaper Class="form-panel mb-4" Elevation="0"><MudGrid>
                <MudItem xs="12" md="4"><MudTextField @bind-Value="_documentType" Label="نوع سند" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" md="5"><MudTextField @bind-Value="_documentDescription" Label="توضیحات سند" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-center"><InputFile OnChange="UploadDocument" disabled="@_uploading" /></MudItem>
            </MudGrid></MudPaper>
        }
        @if (_detail!.Documents.Count == 0) { <EmptyState Title="سندی ثبت نشده" Description="بارنامه، حواله تحویل و PDF رسید اینجا نمایش داده می‌شود." /> }
        else
        {
            <MudTable Items="_detail.Documents" Dense="true"><HeaderContent><MudTh>نوع</MudTh><MudTh>نام فایل</MudTh><MudTh>تاریخ</MudTh><MudTh>شرح</MudTh><MudTh>عملیات</MudTh></HeaderContent>
            <RowTemplate><MudTd>@context.DocumentType</MudTd><MudTd>@(context.OriginalFileName ?? "—")</MudTd><MudTd><DateDisplay Value="@context.UploadedAt" IncludeTime="true" /></MudTd><MudTd>@(context.Description ?? "—")</MudTd>
            <MudTd><MudIconButton Icon="@Icons.Material.Filled.Download" OnClick="@(() => DownloadDocument(context.Id))" />@if(CanManageDocuments){<MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="@(() => DeleteDocument(context.Id))" />}</MudTd></RowTemplate></MudTable>
        }
    </div>;

    private RenderFragment ReportsTab() => @<MudPaper Class="form-panel" Elevation="0">
        <MudText Typo="Typo.h6">گزارش رسمی رسید انبار</MudText>
        <div class="report-actions mt-4">
            <PermissionView Permission="@WarehouseUiPolicy.ReportView"><MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Preview" Disabled="_pdfLoading" OnClick="TogglePreview">پیش‌نمایش</MudButton></PermissionView>
            <PermissionView Permission="@WarehouseUiPolicy.ReportView"><MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="_pdfLoading" OnClick="OpenPdf">خروجی PDF</MudButton></PermissionView>
            <PermissionView Permission="@WarehouseUiPolicy.ReportExport"><MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.SaveAlt" OnClick="SaveReport">ذخیره در اسناد پرونده</MudButton></PermissionView>
        </div>
        @if (_pdfLoading) { <MudProgressLinear Indeterminate="true" Class="mt-4" /> }
        @if (_showPreview && _pdfDataUrl is not null) { <div class="report-preview"><iframe src="@_pdfDataUrl" title="پیش‌نمایش رسید انبار"></iframe></div> }
    </MudPaper>;

    private static RenderFragment Info(string label, string value) => @<div class="summary-item"><span>@label</span><strong>@value</strong></div>;

    private async Task ChangeStatus(string action, object request, string success)
    {
        if (!await Confirm("تأیید اقدام", "این اقدام روی رسید انبار اعمال شود؟", Color.Primary)) return;
        _busy = true;
        try { await Api.ChangeWarehouseReceiptStatusAsync(Id, action, request); _comment = null; await Load(); Snackbar.Add(success, Severity.Success); }
        catch (Exception ex) { Snackbar.Add("اقدام ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private Task Cancel()
    {
        if (string.IsNullOrWhiteSpace(_comment)) { Snackbar.Add("برای لغو رسید، دلیل الزامی است.", Severity.Warning); return Task.CompletedTask; }
        return ChangeStatus("cancel", new CancelWarehouseReceiptRequest(_comment), "رسید لغو شد.");
    }

    private async Task RemoveItem(Guid itemId)
    {
        if (!await Confirm("حذف قلم", "قلم از رسید حذف شود؟", Color.Error)) return;
        try { await Api.RemoveWarehouseReceiptItemAsync(Id, itemId); await Load(); Snackbar.Add("قلم حذف شد.", Severity.Success); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task UploadDocument(InputFileChangeEventArgs e)
    {
        _uploading = true;
        try
        {
            var file = e.File;
            await using var stream = file.OpenReadStream(_maxUploadBytes);
            await Api.UploadWarehouseReceiptDocumentAsync(Id, stream, file.Name, string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType, _documentType, _documentDescription);
            _documentDescription = null; await Load(); Snackbar.Add("سند بارگذاری شد.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("بارگذاری ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _uploading = false; }
    }

    private async Task DownloadDocument(Guid documentId)
    {
        try { var file = await Api.DownloadWarehouseReceiptDocumentAsync(Id, documentId); await JS.InvokeVoidAsync("petroProcureDownloadFile", file.Content, file.ContentType, file.FileName); }
        catch (Exception ex) { Snackbar.Add("دانلود سند ناموفق بود: " + ex.Message, Severity.Error); }
    }

    private async Task DeleteDocument(Guid documentId)
    {
        if (!await Confirm("حذف سند", "سند رسید انبار حذف نرم شود؟", Color.Error)) return;
        try { await Api.DeleteWarehouseReceiptDocumentAsync(Id, documentId); await Load(); Snackbar.Add("سند حذف شد.", Severity.Success); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task TogglePreview() { _showPreview = !_showPreview; if (_showPreview) await EnsurePdf(); }
    private async Task OpenPdf() { await EnsurePdf(); if (_pdfDataUrl is not null) await JS.InvokeVoidAsync("open", _pdfDataUrl, "_blank"); }
    private async Task EnsurePdf()
    {
        if (_pdfDataUrl is not null) return;
        _pdfLoading = true;
        try { var bytes = await Api.GetWarehouseReceiptPdfAsync(Id); _pdfDataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}"; }
        catch (Exception ex) { Snackbar.Add("دریافت گزارش ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _pdfLoading = false; }
    }
    private async Task SaveReport()
    {
        try { await Api.SaveWarehouseReceiptPdfAsync(Id); await Load(); Snackbar.Add("گزارش در اسناد پرونده ذخیره شد.", Severity.Success); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
    private async Task<bool> Confirm(string title, string message, Color color)
    {
        var dialog = await Dialog.ShowAsync<ConfirmDialog>(title, new DialogParameters { { "Message", message }, { "ConfirmColor", color } });
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }
}
