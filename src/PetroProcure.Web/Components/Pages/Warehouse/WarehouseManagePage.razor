@page "/warehouse/manage"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>مدیریت انبارها</PageTitle>
<PageHeader Title="مدیریت انبارها" Subtitle="تعریف و نگهداری انبارهای قابل استفاده در رسید و موجودی" />

@if (_loading) { <LoadingOverlay Visible="true" Text="در حال دریافت انبارها..." /> }
else if (_error is not null) { <RetryPanel Message="@_error" OnRetry="Load" /> }
else
{
    <MudPaper Class="form-panel mb-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">انبار جدید</MudText>
        <MudGrid>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="_code" Label="کد" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_name" Label="نام انبار" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_location" Label="موقعیت" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_description" Label="توضیحات" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="1" Class="d-flex align-center"><MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving" OnClick="Create">ثبت</MudButton></MudItem>
        </MudGrid>
    </MudPaper>

    @if (_items.Count == 0) { <EmptyState Title="انباری ثبت نشده" Description="انبار مرکزی از seed اولیه اضافه می‌شود؛ در صورت نبود، از همین فرم ایجاد کنید." /> }
    else
    {
        <MudTable Items="_items" Dense="true" Hover="true">
            <HeaderContent><MudTh>کد</MudTh><MudTh>نام</MudTh><MudTh>موقعیت</MudTh><MudTh>فعال</MudTh><MudTh>توضیحات</MudTh></HeaderContent>
            <RowTemplate><MudTd>@context.Code</MudTd><MudTd>@context.Name</MudTd><MudTd>@(context.Location ?? "—")</MudTd><MudTd>@(context.IsActive ? "بله" : "خیر")</MudTd><MudTd>@(context.Description ?? "—")</MudTd></RowTemplate>
        </MudTable>
    }
}

@code {
    private List<WarehouseDto> _items = [];
    private bool _loading = true, _saving;
    private string? _error, _code, _name, _location, _description;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Access.HasPermission(WarehouseUiPolicy.ManageWarehouses)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        try { _items = (await Api.GetWarehousesAsync(new(IncludeInactive: true, PageSize: 200))).Items.ToList(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(_code) || string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("کد و نام انبار الزامی است.", Severity.Warning);
            return;
        }
        _saving = true;
        try
        {
            await Api.CreateWarehouseAsync(new(_code, _name, _location, _description));
            _code = _name = _location = _description = null;
            await Load();
            Snackbar.Add("انبار ثبت شد.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("ثبت انبار ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _saving = false; }
    }
}
