@page "/purchase/tenders"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>مناقصات</PageTitle>
<PageHeader Title="فهرست مناقصات" Subtitle="مدیریت فرآیند رسمی مناقصه‌های متصل به پرونده خرید">
    <Actions>
        @if (Access.HasPermission(TenderUiPolicy.Create))
        {
            <MudButton Href="/purchase/tenders/create" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">ایجاد مناقصه</MudButton>
        }
    </Actions>
</PageHeader>

<MudPaper Class="filter-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="3"><MudTextField @bind-Value="_search" Label="جستجو" Immediate="true" /></MudItem>
        <MudItem xs="12" md="2"><MudTextField @bind-Value="_purchaseFileNumber" Label="شماره پرونده" Immediate="true" /></MudItem>
        <MudItem xs="12" md="2"><MudSelect T="TenderStatus?" @bind-Value="_status" Label="وضعیت" Clearable="true">@foreach(var s in Enum.GetValues<TenderStatus>()){<MudSelectItem T="TenderStatus?" Value="@s">@TenderUiPolicy.StatusText(s)</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="2"><MudSelect T="TenderType?" @bind-Value="_type" Label="نوع" Clearable="true">@foreach(var t in Enum.GetValues<TenderType>()){<MudSelectItem T="TenderType?" Value="@t">@TenderUiPolicy.TypeText(t)</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="3" Class="d-flex align-end gap-2"><MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Primary">اعمال فیلتر</MudButton><MudButton OnClick="Clear" Variant="Variant.Text">پاک‌سازی</MudButton></MudItem>
    </MudGrid>
</MudPaper>

<DataStateView TItem="TenderSummaryDto" Loading="_loading" Error="_error" Retry="Load">
    @if (_items.Count == 0)
    {
        <EmptyState Title="مناقصه‌ای یافت نشد" Description="با تغییر فیلترها یا ایجاد مناقصه جدید شروع کنید." />
    }
    else
    {
        <MudTable Items="_items" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>شماره مناقصه</MudTh><MudTh>پرونده خرید</MudTh><MudTh>عنوان</MudTh><MudTh>وضعیت</MudTh><MudTh>نوع</MudTh><MudTh>اقلام</MudTh><MudTh>شرکت‌کنندگان</MudTh><MudTh>مهلت پیشنهاد</MudTh><MudTh>عملیات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.TenderNumber</MudTd>
                <MudTd>@(context.PurchaseFileNumber ?? "—")</MudTd>
                <MudTd>@context.Title</MudTd>
                <MudTd><StatusChip Text="@TenderUiPolicy.StatusText(context.Status)" /></MudTd>
                <MudTd>@TenderUiPolicy.TypeText(context.TenderType)</MudTd>
                <MudTd>@context.ItemCount</MudTd>
                <MudTd>@context.ParticipantCount</MudTd>
                <MudTd><DateDisplay Value="@context.SubmissionDeadline" /></MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" Href="@($"/purchase/tenders/{context.Id}")">مشاهده</MudButton>
                    @if (TenderUiPolicy.CanPublish(context.Status, context.ItemCount, context.ParticipantCount, Access.HasPermission))
                    {
                        <MudButton Size="Size.Small" Color="Color.Primary" OnClick="@(() => Publish(context.Id))">انتشار</MudButton>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent><MudTablePager PageSizeOptions="new[]{10,20,50}" /></PagerContent>
        </MudTable>
    }
</DataStateView>

@code {
    private bool _loading = true;
    private string? _error, _search, _purchaseFileNumber;
    private TenderStatus? _status;
    private TenderType? _type;
    private List<TenderSummaryDto> _items = [];

    protected override async Task OnInitializedAsync()
    {
        if (!Access.HasPermission(TenderUiPolicy.View)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        try
        {
            var result = await Api.GetTendersAsync(new(SearchTerm: _search, PurchaseFileNumber: _purchaseFileNumber, Status: _status, TenderType: _type, PageNumber: 1, PageSize: 50));
            _items = result.Items.ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Clear()
    {
        _search = _purchaseFileNumber = null; _status = null; _type = null; await Load();
    }

    private async Task Publish(Guid id)
    {
        try { await Api.PublishTenderAsync(id); Snackbar.Add("مناقصه منتشر شد.", Severity.Success); await Load(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
}
