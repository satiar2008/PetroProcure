@page "/purchase/tenders/{Id:guid}"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService Dialog

<PageTitle>جزئیات مناقصه</PageTitle>
<PageHeader Title="@(_detail?.Tender.TenderNumber ?? "جزئیات مناقصه")" Subtitle="@(_detail?.Tender.Title ?? "در حال دریافت اطلاعات")">
    <Actions>
        @if (_detail is not null && TenderUiPolicy.CanPublish(_detail.Tender.Status, _detail.Items.Count, _detail.Participants.Count, Access.HasPermission))
        { <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy" OnClick="Publish">انتشار</MudButton> }
        @if (_detail is not null && TenderUiPolicy.CanCancel(_detail.Tender.Status, Access.HasPermission))
        { <MudButton Color="Color.Error" Variant="Variant.Outlined" Disabled="_busy" OnClick="Cancel">لغو</MudButton> }
        @if (_detail is not null && Access.HasPermission(ContractUiPolicy.Create))
        { <MudButton Color="Color.Success" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AssignmentTurnedIn" Href="@($"/purchase/contracts/from-tender/{Id}")">ایجاد قرارداد</MudButton> }
    </Actions>
</PageHeader>

<DataStateView TItem="TenderItemDto" Loading="_loading" Error="_error" Retry="Load">
@if (_detail is not null)
{
<MudTabs Rounded="true" PanelClass="pa-4">
    <MudTabPanel Text="خلاصه" Icon="@Icons.Material.Filled.Info">
        <MudGrid>
            <MudItem xs="12" md="4">@Info("شماره مناقصه", _detail.Tender.TenderNumber)</MudItem>
            <MudItem xs="12" md="4">@Info("وضعیت", TenderUiPolicy.StatusText(_detail.Tender.Status))</MudItem>
            <MudItem xs="12" md="4">@Info("نوع", TenderUiPolicy.TypeText(_detail.Tender.TenderType))</MudItem>
            <MudItem xs="12" md="6"><MudAlert Severity="Severity.Info">پرونده خرید: <MudLink Href="@($"/purchase/files/{_detail.Tender.PurchaseFileId}")">@(_detail.Tender.PurchaseFileNumber ?? "مشاهده پرونده")</MudLink></MudAlert></MudItem>
            @if (_detail.Tender.SourceInquiryId.HasValue)
            { <MudItem xs="12" md="6"><MudAlert Severity="Severity.Info">استعلام مبنا: <MudLink Href="@($"/purchase/inquiries/{_detail.Tender.SourceInquiryId}")">@(_detail.Tender.SourceInquiryNumber ?? "مشاهده استعلام")</MudLink></MudAlert></MudItem> }
            <MudItem xs="12" md="3">@DateInfo("تاریخ ایجاد", _detail.Tender.CreatedAt)</MudItem>
            <MudItem xs="12" md="3">@DateInfo("تاریخ صدور", _detail.Tender.IssueDate)</MudItem>
            <MudItem xs="12" md="3">@DateInfo("مهلت ارسال", _detail.Tender.SubmissionDeadline)</MudItem>
            <MudItem xs="12" md="3">@DateInfo("گشایش", _detail.Tender.OpeningDate)</MudItem>
            <MudItem xs="12">@Info("توضیحات", _detail.Tender.Description ?? "—")</MudItem>
        </MudGrid>
    </MudTabPanel>
    <MudTabPanel Text="اقلام" Icon="@Icons.Material.Filled.Inventory2">
        @foreach (var group in _detail.Items.GroupBy(x => new { x.MescGeneralGroupCode, x.GeneralDescription }))
        {
            <MudExpansionPanel Text="@($"{group.Key.MescGeneralGroupCode} — {group.Key.GeneralDescription}")">
                <MudTable Items="group" Dense="true"><HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>مقدار</MudTh><MudTh>شرح فنی</MudTh></HeaderContent><RowTemplate><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.Quantity</MudTd><MudTd>@(context.TechnicalDescription ?? "—")</MudTd></RowTemplate></MudTable>
            </MudExpansionPanel>
        }
    </MudTabPanel>
    <MudTabPanel Text="شرکت‌کنندگان" Icon="@Icons.Material.Filled.Business">
        @if (Access.HasPermission("Tender.ManageParticipants") && _detail.Tender.Status is TenderStatus.Draft or TenderStatus.ReadyToPublish)
        { <SupplierSelector Value="_supplier" ValueChanged="AddSupplier" /> }
        <MudTable Items="_detail.Participants" Dense="true"><HeaderContent><MudTh>کد</MudTh><MudTh>نام</MudTh><MudTh>وضعیت</MudTh><MudTh>دعوت</MudTh></HeaderContent><RowTemplate><MudTd>@context.SupplierCode</MudTd><MudTd>@context.SupplierName</MudTd><MudTd>@SupplierStatusText(context.Status)</MudTd><MudTd><DateDisplay Value="@context.InvitedAt" /></MudTd></RowTemplate></MudTable>
    </MudTabPanel>
    <MudTabPanel Text="پیشنهادها" Icon="@Icons.Material.Filled.RequestQuote">
        @if (Access.HasPermission(TenderUiPolicy.ReceiveBid) && _detail.Participants.Count > 0)
        { <MudButton Class="mb-3" Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddSampleBid">ثبت پیشنهاد نمونه</MudButton> }
        <MudTable Items="_detail.Bids" Dense="true"><HeaderContent><MudTh>تأمین‌کننده</MudTh><MudTh>شماره</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>امتیاز فنی</MudTh><MudTh>امتیاز مالی</MudTh><MudTh>وضعیت</MudTh></HeaderContent><RowTemplate><MudTd>@context.SupplierName</MudTd><MudTd>@(context.BidNumber ?? "—")</MudTd><MudTd>@Money(context.FinalAmount)</MudTd><MudTd>@context.TechnicalScore</MudTd><MudTd>@context.CommercialScore</MudTd><MudTd>@BidStatusText(context.Status)</MudTd></RowTemplate></MudTable>
    </MudTabPanel>
    <MudTabPanel Text="ارزیابی" Icon="@Icons.Material.Filled.FactCheck">
        @if (Access.HasPermission(TenderUiPolicy.Evaluate) && _detail.Bids.Count > 0)
        { <MudButton Class="mb-3" Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddSampleEvaluation">ثبت ارزیابی نمونه</MudButton> }
        <MudTable Items="_detail.Evaluations" Dense="true"><HeaderContent><MudTh>نوع</MudTh><MudTh>نتیجه</MudTh><MudTh>امتیاز</MudTh><MudTh>تاریخ</MudTh></HeaderContent><RowTemplate><MudTd>@EvaluationTypeText(context.EvaluationType)</MudTd><MudTd>@EvaluationResultText(context.Result)</MudTd><MudTd>@context.Score</MudTd><MudTd><DateDisplay Value="@context.EvaluationDate" IncludeTime="true" /></MudTd></RowTemplate></MudTable>
    </MudTabPanel>
    <MudTabPanel Text="مقایسه" Icon="@Icons.Material.Filled.CompareArrows">
        <MudButton OnClick="LoadComparison" Variant="Variant.Outlined">بارگذاری مقایسه</MudButton>
        @if (_comparison is null) { <EmptyState Title="مقایسه‌ای برای نمایش نیست" Description="پس از ثبت پیشنهادها، جدول مقایسه قابل مشاهده است." /> }
        else { <MudTable Items="_comparison.Suppliers" Dense="true"><HeaderContent><MudTh>تأمین‌کننده</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>تحویل</MudTh><MudTh>پرداخت</MudTh><MudTh>امتیاز نهایی</MudTh><MudTh>برنده</MudTh><MudTh>عملیات</MudTh></HeaderContent><RowTemplate><MudTd>@context.SupplierName</MudTd><MudTd>@Money(context.FinalAmount)</MudTd><MudTd>@context.DeliveryTerms</MudTd><MudTd>@context.PaymentTerms</MudTd><MudTd>@context.FinalScore</MudTd><MudTd>@(context.IsSelected ? "بله" : "—")</MudTd><MudTd>@if(Access.HasPermission(TenderUiPolicy.SelectWinner) && !context.IsSelected){<MudButton Size="Size.Small" Disabled="_busy" OnClick="@(()=>SelectWinner(context.TenderBidId))">انتخاب برنده</MudButton>}</MudTd></RowTemplate></MudTable> }
        <MudAlert Severity="Severity.Warning" Class="mt-3">تحلیل و مقایسه صرفاً ابزار کمکی است؛ تصمیم نهایی با انسان/کمیسیون مجاز است.</MudAlert>
    </MudTabPanel>
    <MudTabPanel Text="جلسات کمیسیون" Icon="@Icons.Material.Filled.Groups">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6">جلسات کمیسیون مرتبط با این مناقصه</MudText>
            @if (Access.HasPermission(CommissionUiPolicy.Create))
            {
                <MudButton Href="@($"/tender-commission/sessions/from-tender/{Id}")" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">ایجاد جلسه کمیسیون</MudButton>
            }
        </div>
        @if (_commissionLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_commissionError))
        {
            <RetryPanel Message="@_commissionError" OnRetry="LoadCommissionSessions" />
        }
        else if (_commissionSessions.Count == 0)
        {
            <EmptyState Title="جلسه‌ای ثبت نشده" Description="برای این مناقصه هنوز جلسه کمیسیون ایجاد نشده است." />
        }
        else
        {
            <MudTable Items="_commissionSessions" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>شماره جلسه</MudTh><MudTh>عنوان</MudTh><MudTh>وضعیت</MudTh><MudTh>تاریخ جلسه</MudTh><MudTh>اعضا</MudTh><MudTh>تصمیمات</MudTh><MudTh>عملیات</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.SessionNumber</MudTd>
                    <MudTd>@context.Title</MudTd>
                    <MudTd><StatusChip Text="@CommissionUiPolicy.StatusText(context.Status)" Color="@CommissionUiPolicy.StatusColor(context.Status)" /></MudTd>
                    <MudTd><DateDisplay Value="@context.SessionDate" IncludeTime="true" /></MudTd>
                    <MudTd>@context.MemberCount</MudTd>
                    <MudTd>@context.DecisionCount</MudTd>
                    <MudTd><MudButton Size="Size.Small" Href="@($"/tender-commission/sessions/{context.Id}")">مشاهده</MudButton></MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
    <MudTabPanel Text="اسناد" Icon="@Icons.Material.Filled.AttachFile">
        <TenderDocumentsPanel TenderId="Id" />
    </MudTabPanel>
    <MudTabPanel Text="گزارش‌ها" Icon="@Icons.Material.Filled.PictureAsPdf">
        <TenderReportsPanel TenderId="Id" />
    </MudTabPanel>
    <MudTabPanel Text="ارتباطات" Icon="@Icons.Material.Filled.Link">
        <MudAlert Severity="Severity.Info" Class="mb-3">پرونده خرید، استعلام مبنا و جلسات کمیسیون از تب‌های همین صفحه قابل مشاهده هستند.</MudAlert>
        @if (Access.HasPermission(ContractUiPolicy.Create))
        {
            <MudButton Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AssignmentTurnedIn"
                       Href="@($"/purchase/contracts/from-tender/{Id}")">ایجاد قرارداد از این مناقصه</MudButton>
        }
        <MudAlert Severity="Severity.Warning" Class="mt-3">اتصال قرارداد به سفارش خرید در فازهای بعدی انجام می‌شود.</MudAlert>
    </MudTabPanel>
</MudTabs>
}
</DataStateView>

@code {
    [Parameter] public Guid Id { get; set; }
    private TenderDetailDto? _detail;
    private TenderComparisonDto? _comparison;
    private SupplierLookupDto? _supplier;
    private List<TenderCommissionSessionSummaryDto> _commissionSessions = [];
    private bool _loading = true;
    private bool _busy;
    private bool _commissionLoading;
    private string? _error;
    private string? _commissionError;

    protected override async Task OnInitializedAsync()
    {
        if (!Access.HasPermission(TenderUiPolicy.View)) { Navigation.NavigateTo("/access-denied"); return; }
        await Load();
    }
    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            _detail = await Api.GetTenderAsync(Id);
            await LoadCommissionSessions();
        }
        catch(Exception ex){_error=UiErrorText.From(ex);}
        finally{_loading=false;}
    }
    private async Task LoadCommissionSessions()
    {
        _commissionLoading = true;
        _commissionError = null;
        try { _commissionSessions = (await Api.GetTenderCommissionSessionsAsync(Id)).ToList(); }
        catch(Exception ex) { _commissionError = UiErrorText.From(ex); }
        finally { _commissionLoading = false; }
    }
    private RenderFragment Info(string label,string value)=>@<MudPaper Class="pa-3" Elevation="0" Outlined="true"><MudText Typo="Typo.caption">@label</MudText><MudText><strong>@value</strong></MudText></MudPaper>;
    private RenderFragment DateInfo(string label,DateTime? value)=>@<MudPaper Class="pa-3" Elevation="0" Outlined="true"><MudText Typo="Typo.caption">@label</MudText><MudText><strong><DateDisplay Value="@value" /></strong></MudText></MudPaper>;
    private async Task Publish()
    {
        if (!await Confirm("انتشار مناقصه", "مناقصه برای دریافت پیشنهادها منتشر شود؟", Color.Primary)) return;
        await Execute(async () => await Api.PublishTenderAsync(Id), "مناقصه منتشر شد.");
    }
    private async Task Cancel()
    {
        if (!await Confirm("لغو مناقصه", "مناقصه لغو شود؟ این اقدام در گردش کار قابل مشاهده خواهد بود.", Color.Error)) return;
        await Execute(async () => await Api.CancelTenderAsync(Id,"لغو از رابط کاربری"), "مناقصه لغو شد.");
    }
    private async Task AddSupplier(SupplierLookupDto? supplier){if(supplier is null)return;try{await Api.AddTenderParticipantAsync(Id,new(supplier.Id));Snackbar.Add("تأمین‌کننده اضافه شد.",Severity.Success);_supplier=null;await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
    private async Task AddSampleBid(){var p=_detail?.Participants.FirstOrDefault();if(p is null)return;try{await Api.AddTenderBidAsync(Id,new(p.Id,"BID-"+DateTime.Now.Ticks,"IRR",1000,1000,"تحویل طبق توافق","پرداخت طبق قرارداد",null,null));Snackbar.Add("پیشنهاد ثبت شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
    private async Task AddSampleEvaluation(){var b=_detail?.Bids.FirstOrDefault();if(b is null)return;try{await Api.AddTenderEvaluationAsync(Id,new(b.Id,TenderEvaluationType.Technical,80,TenderEvaluationResult.Passed,"ارزیابی نمونه"));Snackbar.Add("ارزیابی ثبت شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
    private async Task LoadComparison(){try{_comparison=await Api.GetTenderComparisonAsync(Id);}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
    private async Task SelectWinner(Guid bidId)
    {
        if (!await Confirm("انتخاب برنده", "این پیشنهاد به‌عنوان برنده مناقصه ثبت شود؟", Color.Success)) return;
        await Execute(async () =>
        {
            await Api.SelectTenderWinnerAsync(Id,new(bidId,"انتخاب از جدول مقایسه","تصمیم انسانی/کمیسیون"));
            await LoadComparison();
        }, "برنده انتخاب شد.");
    }

    private async Task Execute(Func<Task> action, string successMessage)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await action();
            Snackbar.Add(successMessage, Severity.Success);
            await Load();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorText.From(ex), Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<bool> Confirm(string title, string message, Color color)
    {
        var dialog = await Dialog.ShowAsync<ConfirmDialog>(title, new DialogParameters
        {
            ["Message"] = message,
            ["ConfirmColor"] = color
        });
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private static string SupplierStatusText(TenderParticipantStatus status) => status switch
    {
        TenderParticipantStatus.Draft => "پیش‌نویس",
        TenderParticipantStatus.Invited => "دعوت‌شده",
        TenderParticipantStatus.Submitted => "پیشنهاد ثبت‌شده",
        TenderParticipantStatus.Declined => "انصراف",
        TenderParticipantStatus.Disqualified => "رد صلاحیت",
        TenderParticipantStatus.Qualified => "تأیید صلاحیت",
        TenderParticipantStatus.NoResponse => "بدون پاسخ",
        _ => status.ToString()
    };
    private static string BidStatusText(TenderBidStatus status) => status switch
    {
        TenderBidStatus.Draft => "پیش‌نویس",
        TenderBidStatus.Submitted => "ثبت‌شده",
        TenderBidStatus.Received => "دریافت‌شده",
        TenderBidStatus.UnderReview => "در حال بررسی",
        TenderBidStatus.Accepted => "پذیرفته",
        TenderBidStatus.Selected => "برنده",
        TenderBidStatus.Rejected => "رد شده",
        _ => status.ToString()
    };
    private static string EvaluationTypeText(TenderEvaluationType type) => type switch
    {
        TenderEvaluationType.Qualification => "صلاحیت",
        TenderEvaluationType.Technical => "فنی",
        TenderEvaluationType.Commercial => "مالی",
        TenderEvaluationType.Final => "نهایی",
        _ => type.ToString()
    };
    private static string EvaluationResultText(TenderEvaluationResult result) => result switch
    {
        TenderEvaluationResult.Passed => "قبول",
        TenderEvaluationResult.Failed => "رد",
        TenderEvaluationResult.Conditional => "مشروط",
        TenderEvaluationResult.NeedsReview => "نیازمند بررسی",
        _ => result.ToString()
    };
    private static string Money(decimal? value) => value.HasValue ? value.Value.ToString("N0") : "—";
}
