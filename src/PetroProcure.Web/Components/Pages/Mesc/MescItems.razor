@page "/orders/mesc/items"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject IUserAccessContext Access
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
<PageTitle>اقلام MESC</PageTitle>
<PageHeader Title="اقلام کالا" Subtitle="جستجو و مدیریت اقلام کاتالوگ MESC" />

@if (_loading) { <LoadingOverlay Visible="true" /> }
else if (_error is not null) { <EmptyState Title="خطا در دریافت اقلام" Description="@_error"><Action><MudButton OnClick="Load">تلاش مجدد</MudButton></Action></EmptyState> }
else
{
<MudPaper Class="form-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="5"><MudTextField @bind-Value="_search" Label="جستجوی کد یا شرح" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" /></MudItem>
        <MudItem xs="12" md="3"><MudSelect T="string" @bind-Value="_groupCode" Label="گروه عمومی" Clearable="true"><MudSelectItem Value="@string.Empty">همه گروه‌ها</MudSelectItem>@foreach(var g in _groups){<MudSelectItem Value="@g.Code">@g.Code — @g.GeneralDescription</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="2"><MudSelect T="string" @bind-Value="_status" Label="وضعیت"><MudSelectItem Value="@("all")">همه</MudSelectItem><MudSelectItem Value="@("active")">فعال</MudSelectItem><MudSelectItem Value="@("inactive")">غیرفعال</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">@if(Access.HasPermission("Item.Create")){<MudButton FullWidth="true" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="Create">ایجاد قلم</MudButton>}</MudItem>
    </MudGrid>
    <MudTable Items="Filtered" Dense="true" Hover="true" RowsPerPage="10" Class="mt-4">
        <HeaderContent><MudTh>کد MESC</MudTh><MudTh>کد گروه</MudTh><MudTh>شرح عمومی</MudTh><MudTh>شرح اختصاصی</MudTh><MudTh>واحد</MudTh><MudTh>وضعیت</MudTh><MudTh></MudTh></HeaderContent>
        <RowTemplate>
            <MudTd><MescCodeDisplay Code="@context.Code" /></MudTd><MudTd>@context.GeneralGroupCode</MudTd><MudTd>@context.GeneralDescription</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.UnitOfMeasure</MudTd>
            <MudTd><StatusChip Status="@(context.IsActive?"Active":"Inactive")" /></MudTd>
            <MudTd>
                @if(Access.HasPermission("Item.Edit")){<MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(()=>Edit(context))" />}
                @if(Access.HasPermission("Item.ActivateDeactivate")){<MudIconButton Icon="@(context.IsActive?Icons.Material.Filled.PauseCircle:Icons.Material.Filled.PlayCircle)" Color="@(context.IsActive?Color.Warning:Color.Success)" OnClick="@(()=>ToggleActive(context))" />}
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><EmptyState Title="قلمی یافت نشد" Description="فیلترها را تغییر دهید یا قلم جدید ثبت کنید." /></NoRecordsContent>
        <PagerContent><MudTablePager PageSizeOptions="new int[]{10,25,50}" /></PagerContent>
    </MudTable>
</MudPaper>
}
@code{
private List<MescItemDto>_items=[];private List<MescGeneralGroupDto>_groups=[];private bool _loading=true;private string?_error;private string _search="",_groupCode="",_status="all";
private IEnumerable<MescItemDto> Filtered=>_items.Where(x=>(string.IsNullOrWhiteSpace(_search)||x.Code.Contains(_search.Trim(),StringComparison.OrdinalIgnoreCase)||x.GeneralGroupCode.Contains(_search.Trim(),StringComparison.OrdinalIgnoreCase)||x.GeneralDescription.Contains(_search.Trim(),StringComparison.OrdinalIgnoreCase)||x.SpecificDescription.Contains(_search.Trim(),StringComparison.OrdinalIgnoreCase))&&(string.IsNullOrWhiteSpace(_groupCode)||x.GeneralGroupCode==_groupCode)&&(_status=="all"||(_status=="active"&&x.IsActive)||(_status=="inactive"&&!x.IsActive)));
protected override async Task OnAfterRenderAsync(bool firstRender){if(!firstRender)return;if(!Access.HasPermission("Item.View")){Navigation.NavigateTo("/access-denied");return;}await Load();StateHasChanged();}
private async Task Load(){_loading=true;_error=null;try{var items=Api.GetMescItemsAsync(true);var groups=Api.GetMescGroupsAsync(true);await Task.WhenAll(items,groups);_items=await items;_groups=await groups;}catch(Exception ex){_error="امکان دریافت اقلام وجود ندارد.";Snackbar.Add(UiErrorText.From(ex),Severity.Error);}finally{_loading=false;}}
private async Task Create(){var dialog=await Dialog.ShowAsync<MescItemDialog>("ایجاد قلم MESC");var result=await dialog.Result;if(result?.Canceled!=false||result.Data is not ValueTuple<string,string,string,string> value)return;try{await EnsureGroup(value.Item1,value.Item2);await Api.CreateMescItemAsync(new(value.Item1,value.Item3,value.Item4,value.Item2));Snackbar.Add("قلم کالا ایجاد شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
private async Task Edit(MescItemDto model){var dialog=await Dialog.ShowAsync<MescItemDialog>("ویرایش قلم MESC",new DialogParameters{{"Model",model}});var result=await dialog.Result;if(result?.Canceled!=false||result.Data is not ValueTuple<string,string,string,string> value)return;try{await EnsureGroup(value.Item1,value.Item2);await Api.UpdateMescItemAsync(model.Id,new(value.Item1,value.Item3,value.Item4,value.Item2));Snackbar.Add("قلم کالا ویرایش شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
private async Task EnsureGroup(string itemCode,string generalDescription){var groupCode=itemCode[..6];if(_groups.Any(x=>x.Code==groupCode))return;if(string.IsNullOrWhiteSpace(generalDescription))throw new InvalidOperationException("شرح عمومی گروه برای ایجاد گروه جدید الزامی است.");await Api.CreateMescGroupAsync(new(groupCode,generalDescription));Snackbar.Add($"گروه عمومی {groupCode} ایجاد شد.",Severity.Info);}
private async Task ToggleActive(MescItemDto item){if(item.IsActive){var dialog=await Dialog.ShowAsync<ConfirmDialog>("غیرفعال‌سازی قلم",new DialogParameters{{"Message",$"قلم «{item.Code}» غیرفعال شود؟"},{"ConfirmColor",Color.Warning}});var result=await dialog.Result;if(result?.Canceled!=false)return;}try{await Api.SetMescItemActiveAsync(item.Id,!item.IsActive);Snackbar.Add(item.IsActive?"قلم غیرفعال شد.":"قلم فعال شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(UiErrorText.From(ex),Severity.Error);}}
}
