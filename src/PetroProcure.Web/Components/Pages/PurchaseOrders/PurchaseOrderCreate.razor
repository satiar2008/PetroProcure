@page "/purchase/purchase-orders/create"
@rendermode InteractiveServer
@inject IPetroProcureApiClient Api
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>ایجاد سفارش خرید</PageTitle>
<PageHeader Title="ایجاد سفارش خرید" Subtitle="ثبت سفارش خرید دستی مرتبط با پرونده خرید" />

<MudPaper Class="form-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="4"><MudSelect T="Guid?" @bind-Value="_purchaseFileId" Label="پرونده خرید" Variant="Variant.Outlined" Clearable="true">@foreach(var file in _files){<MudSelectItem T="Guid?" Value="@file.Id">@file.FileNumber — @file.Title</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="4"><SupplierSelector Value="_supplier" ValueChanged="OnSupplierChanged" Required="true" /></MudItem>
        <MudItem xs="12" md="4"><MudSelect T="PurchaseOrderType" @bind-Value="_type" Label="نوع سفارش" Variant="Variant.Outlined">@foreach(var t in Enum.GetValues<PurchaseOrderType>()){<MudSelectItem Value="@t">@PurchaseOrderUiPolicy.TypeText(t)</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_title" Label="عنوان" Required="true" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><PersianDatePicker @bind-Date="_orderDate" Label="تاریخ سفارش" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><PersianDatePicker @bind-Date="_deliveryDate" Label="موعد تحویل" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudTextField @bind-Value="_currency" Label="ارز" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudNumericField T="decimal?" @bind-Value="_total" Label="مبلغ کل" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudNumericField T="decimal?" @bind-Value="_tax" Label="مالیات" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudNumericField T="decimal?" @bind-Value="_discount" Label="تخفیف" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_deliveryLocation" Label="محل تحویل" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_paymentTerms" Label="شرایط پرداخت" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_deliveryTerms" Label="شرایط تحویل" Lines="2" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="6"><MudTextField @bind-Value="_warrantyTerms" Label="گارانتی" Lines="2" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12"><MudTextField @bind-Value="_description" Label="توضیحات" Lines="3" Variant="Variant.Outlined" /></MudItem>
    </MudGrid>
    <div class="form-actions">
        <MudButton Variant="Variant.Text" Href="/purchase/purchase-orders">انصراف</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving" OnClick="Save">ثبت سفارش خرید</MudButton>
    </div>
</MudPaper>

@code {
    private List<PurchaseFileSummaryDto> _files = [];
    private Guid? _purchaseFileId;
    private SupplierLookupDto? _supplier;
    private string _title = "";
    private string _currency = "IRR";
    private string? _description, _deliveryLocation, _deliveryTerms, _paymentTerms, _warrantyTerms;
    private PurchaseOrderType _type = PurchaseOrderType.DirectPurchase;
    private DateTime? _orderDate = DateTime.Today, _deliveryDate;
    private decimal? _total, _tax, _discount;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        try { _files = (await Api.GetPurchaseFilesAsync(new(PageSize: 100))).Items.ToList(); }
        catch (Exception ex) { Snackbar.Add("دریافت پرونده‌های خرید ناموفق بود: " + ex.Message, Severity.Error); }
    }

    private Task OnSupplierChanged(SupplierLookupDto? supplier) { _supplier = supplier; return Task.CompletedTask; }

    private async Task Save()
    {
        if (_purchaseFileId is null || _supplier is null || string.IsNullOrWhiteSpace(_title))
        { Snackbar.Add("پرونده خرید، تأمین‌کننده و عنوان الزامی است.", Severity.Warning); return; }
        _saving = true;
        try
        {
            var result = await Api.CreatePurchaseOrderAsync(new(_purchaseFileId.Value, _supplier.Id, null, null, null,
                _title, _type, _currency, _total, _tax, _discount, null, _orderDate, _deliveryDate,
                _deliveryLocation, _deliveryTerms, _paymentTerms, _warrantyTerms, null, _description));
            Snackbar.Add("سفارش خرید ایجاد شد.", Severity.Success);
            Navigation.NavigateTo($"/purchase/purchase-orders/{result.PurchaseOrder.Id}");
        }
        catch (Exception ex) { Snackbar.Add("ثبت سفارش خرید ناموفق بود: " + ex.Message, Severity.Error); }
        finally { _saving = false; }
    }
}
