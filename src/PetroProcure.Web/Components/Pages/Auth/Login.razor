@page "/login"
@layout PetroProcure.Web.Components.Layout.AuthLayout
@inject IAuthService Auth
@inject NavigationManager Navigation

<PageTitle>ورود به پتروپروکیور</PageTitle>

<div class="login-page">
    <div class="login-motion" aria-hidden="true">
        <span class="motion-track motion-track-one"></span>
        <span class="motion-track motion-track-two"></span>
        <span class="motion-node motion-node-one"></span>
        <span class="motion-node motion-node-two"></span>
    </div>

    <MudPaper Class="login-shell" Elevation="0">
        <section class="login-hero">
            <div class="login-brand">
                <img class="login-brand-logo" src="/logo/logo.png" alt="PetroProcure" />
                <div>
                    <MudText Typo="Typo.h5" Class="login-brand-title">پتروپروکیور</MudText>
                    <MudText Typo="Typo.body1" Class="login-brand-subtitle">سامانه یکپارچه تدارکات، خرید و گردش‌کار پالایشگاه</MudText>
                </div>
            </div>

            <div class="login-hero-copy">
                <MudText Typo="Typo.h3" Class="login-hero-title">مدیریت امن پرونده‌های خرید</MudText>
                <MudText Typo="Typo.body1" Class="login-hero-text">
                    از کاتالوگ MESC و تقاضای خرید تا پرونده، اسناد، کارتابل و گزارش‌ها؛ همه چیز در یک محیط کنترل‌شده و قابل پیگیری.
                </MudText>
            </div>

            <div class="login-feature-grid">
                @Feature(Icons.Material.Filled.VerifiedUser, "دسترسی مبتنی بر مجوز")
                @Feature(Icons.Material.Filled.AccountTree, "گردش‌کار بین واحدها")
                @Feature(Icons.Material.Filled.FolderOpen, "پرونده مرکزی خرید")
            </div>
        </section>

        <section class="login-card animated-card">
            <div class="login-card-heading">
                <MudText Typo="Typo.h5">ورود به سامانه</MudText>
                <MudText Typo="Typo.body2">برای ادامه، اطلاعات حساب سازمانی خود را وارد کنید.</MudText>
            </div>

            <MudForm @ref="_form">
                <MudTextField @bind-Value="_userName" Label="نام کاربری یا ایمیل"
                              Immediate="true"
                              Required="true" RequiredError="نام کاربری یا ایمیل الزامی است"
                              Variant="Variant.Outlined" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.PersonOutline" />
                <MudTextField @bind-Value="_password" Label="رمز عبور"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Immediate="true"
                              Required="true" RequiredError="رمز عبور الزامی است"
                              Variant="Variant.Outlined" Class="mt-4"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              AdornmentAriaLabel="نمایش یا پنهان‌سازی رمز"
                              OnKeyDown="OnPasswordKeyDown" />
                <MudCheckBox @bind-Value="_rememberMe" Label="مرا به خاطر بسپار" Class="mt-2" />
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">@_error</MudAlert>
                }
                <MudButton FullWidth="true" Color="Color.Primary" Variant="Variant.Filled"
                           Size="Size.Large" Class="login-submit" Disabled="_busy" OnClick="LoginAsync">
                    @(_busy ? "در حال ورود..." : "ورود به سامانه")
                </MudButton>
            </MudForm>

            <div class="login-footer-note">
                <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" />
                <span>ورود شما ثبت و مطابق سیاست‌های امنیتی سازمان کنترل می‌شود.</span>
            </div>

            <div class="login-designer">
                <span>طراحی و توسعه</span>
                <img src="/logo/Me_logo_noBack.png" alt="طراح و سازنده برنامه" />
            </div>
        </section>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    private MudForm? _form;
    private string _userName = "";
    private string _password = "";
    private string? _error;
    private bool _rememberMe;
    private bool _busy;
    private bool _showPassword;

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter" && !_busy)
            await LoginAsync();
    }

    private static RenderFragment Feature(string icon, string text) =>
        @<div class="login-feature animated-card">
            <MudIcon Icon="@icon" />
            <span>@text</span>
        </div>;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && await Auth.IsAuthenticatedAsync())
            Navigation.NavigateTo("/");
    }

    private async Task LoginAsync()
    {
        await _form!.Validate();
        if (!_form.IsValid) return;
        _busy = true;
        _error = null;
        var result = await Auth.LoginAsync(_userName, _password, _rememberMe);
        _busy = false;
        if (!result.Succeeded)
        {
            _error = result.Error;
            return;
        }
        Navigation.NavigateTo(SafeReturnUrl());
    }

    private string SafeReturnUrl() =>
        !string.IsNullOrWhiteSpace(ReturnUrl)
        && !ReturnUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? "/" + ReturnUrl.TrimStart('/')
            : "/";
}
