@page "/purchase/inquiries/from-purchase-file/{PurchaseFileId:guid}"
@inject IPetroProcureApiClient Api
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>ایجاد استعلام از پرونده</PageTitle>
<PageHeader Title="ایجاد استعلام از پرونده خرید" Subtitle="اقلام پرونده کپی و تأمین‌کنندگان انتخاب می‌شوند" />

<DataStateView TItem="PurchaseFileItemDto" Loading="_loading" Error="_error" Retry="Load">
@if(_file is not null){
<MudPaper Class="data-panel" Elevation="0"><MudText Typo="Typo.h6">@_file.FileNumber - @_file.Title</MudText></MudPaper>
<MudPaper Class="form-panel" Elevation="0">
    <MudGrid><MudItem xs="12" md="6"><MudTextField @bind-Value="_title" Label="عنوان استعلام" Variant="Variant.Outlined" /></MudItem><MudItem xs="12" md="3"><MudDatePicker @bind-Date="_deadline" Label="مهلت پاسخ" Variant="Variant.Outlined" /></MudItem></MudGrid>
    <MudText Typo="Typo.subtitle1" Class="mt-4">تأمین‌کنندگان</MudText><SupplierSelector Value="_selectedSupplier" ValueChanged="OnSupplierSelected" />
    <MudChipSet T="string" Class="mt-2">@foreach(var s in _suppliers){<MudChip T="string">@s.SupplierCode - @s.Name</MudChip>}</MudChipSet>
</MudPaper>
<MudTable Items="_file.Items" Dense="true" Class="data-panel"><HeaderContent><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>مقدار</MudTh></HeaderContent><RowTemplate><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.RequestedQuantity</MudTd></RowTemplate></MudTable>
<div class="form-actions"><MudButton Disabled="_saving" Color="Color.Primary" Variant="Variant.Filled" OnClick="Create">ایجاد استعلام</MudButton></div>
}
</DataStateView>

@code {
    [Parameter] public Guid PurchaseFileId { get; set; }
    private bool _loading=true,_saving; private string? _error; private PurchaseFileDto? _file; private string _title=""; private DateTime? _deadline; private SupplierLookupDto? _selectedSupplier; private List<SupplierLookupDto> _suppliers=[];
    protected override Task OnInitializedAsync()=>Load();
    private async Task Load(){_loading=true;try{_file=await Api.GetPurchaseFileAsync(PurchaseFileId);_title=$"استعلام {_file?.FileNumber}";}catch(Exception ex){_error=ex.Message;}finally{_loading=false;}}
    private Task OnSupplierSelected(SupplierLookupDto? s){if(s is not null&&_suppliers.All(x=>x.Id!=s.Id))_suppliers.Add(s);_selectedSupplier=null;return Task.CompletedTask;}
    private async Task Create(){if(_file is null)return;_saving=true;try{var result=await Api.CreateInquiryFromPurchaseFileAsync(PurchaseFileId,new(_title,InquiryType.PriceInquiry,_deadline,null,_file.Items.Select(x=>x.Id).ToArray(),_suppliers.Select(x=>x.Id).ToArray()));Snackbar.Add("استعلام ایجاد شد.",Severity.Success);Navigation.NavigateTo($"/purchase/inquiries/{result.Inquiry.Id}");}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}finally{_saving=false;}}
}
