@page "/purchase/inquiries/{Id:guid}"
@inject IPetroProcureApiClient Api
@inject ISnackbar Snackbar

<PageTitle>جزئیات استعلام</PageTitle>
<PageHeader Title="@(_detail?.Inquiry.InquiryNumber ?? "جزئیات استعلام")" Subtitle="@(_detail?.Inquiry.Title ?? "")">
    <PermissionView Permission="@InquiryUiPolicy.Send"><MudButton OnClick="Send" Color="Color.Primary" Variant="Variant.Outlined">ارسال</MudButton></PermissionView>
</PageHeader>

<DataStateView TItem="InquiryItemDto" Loading="_loading" Error="_error" Retry="Load">
@if(_detail is not null){
<MudTabs Rounded="true" Elevation="0">
<MudTabPanel Text="خلاصه"><MudPaper Class="data-panel" Elevation="0"><div class="summary-grid">
@Info("شماره",_detail.Inquiry.InquiryNumber) @Info("وضعیت",InquiryUiPolicy.StatusText(_detail.Inquiry.Status)) @Info("نوع",InquiryUiPolicy.TypeText(_detail.Inquiry.InquiryType))
<div class="summary-item"><span>تاریخ ایجاد</span><strong><DateDisplay Value="@_detail.Inquiry.CreatedAt" /></strong></div>
<div class="summary-item"><span>مهلت پاسخ</span><strong><DateDisplay Value="@_detail.Inquiry.DeadlineDate" /></strong></div>
<div class="summary-item"><span>ارسال</span><strong><DateDisplay Value="@_detail.Inquiry.SentAt" /></strong></div>
</div></MudPaper></MudTabPanel>
<MudTabPanel Text="اقلام"><MudTable Items="_detail.Items" Dense="true"><HeaderContent><MudTh>گروه</MudTh><MudTh>کد MESC</MudTh><MudTh>شرح</MudTh><MudTh>مقدار</MudTh></HeaderContent><RowTemplate><MudTd>@context.MescGeneralGroupCode</MudTd><MudTd>@context.MescCode</MudTd><MudTd>@context.SpecificDescription</MudTd><MudTd>@context.RequestedQuantity</MudTd></RowTemplate></MudTable></MudTabPanel>
<MudTabPanel Text="تأمین‌کنندگان"><SupplierSelector Value="_supplier" ValueChanged="AddSupplier" /><MudTable Items="_detail.Suppliers" Dense="true"><HeaderContent><MudTh>کد</MudTh><MudTh>نام</MudTh><MudTh>وضعیت</MudTh><MudTh>دعوت</MudTh></HeaderContent><RowTemplate><MudTd>@context.SupplierCode</MudTd><MudTd>@context.SupplierName</MudTd><MudTd>@context.Status</MudTd><MudTd><DateDisplay Value="@context.InvitedAt" /></MudTd></RowTemplate></MudTable></MudTabPanel>
<MudTabPanel Text="پیشنهادها"><PermissionView Permission="@InquiryUiPolicy.ReceiveQuote"><MudButton OnClick="AddQuote" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-3">ثبت پیشنهاد نمونه</MudButton></PermissionView><MudTable Items="_detail.Quotes" Dense="true"><HeaderContent><MudTh>تأمین‌کننده</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>وضعیت</MudTh><MudTh>انتخاب</MudTh></HeaderContent><RowTemplate><MudTd>@_detail.Suppliers.FirstOrDefault(s=>s.SupplierId==context.SupplierId)?.SupplierName</MudTd><MudTd>@context.FinalAmount</MudTd><MudTd>@context.Status</MudTd><MudTd><PermissionView Permission="@InquiryUiPolicy.SelectSupplier"><MudButton Size="Size.Small" OnClick="@(()=>SelectQuote(context.Id))">انتخاب</MudButton></PermissionView></MudTd></RowTemplate></MudTable></MudTabPanel>
<MudTabPanel Text="مقایسه"><MudButton OnClick="LoadComparison" Variant="Variant.Outlined">بارگذاری مقایسه</MudButton>@if(_comparison is null){<EmptyState Title="مقایسه‌ای برای نمایش نیست" Description="پس از ثبت پیشنهادها، مقایسه قابل مشاهده است." />}else{<MudTable Items="_comparison.Suppliers" Dense="true"><HeaderContent><MudTh>تأمین‌کننده</MudTh><MudTh>مبلغ کل</MudTh><MudTh>مبلغ نهایی</MudTh><MudTh>انتخاب‌شده</MudTh></HeaderContent><RowTemplate><MudTd>@context.SupplierName</MudTd><MudTd>@context.TotalAmount</MudTd><MudTd>@context.FinalAmount</MudTd><MudTd>@(context.IsSelected?"بله":"خیر")</MudTd></RowTemplate></MudTable>}</MudTabPanel>
<MudTabPanel Text="اسناد"><EmptyState Title="اسناد استعلام" Description="اتصال کامل به مخزن اسناد در فاز بعدی انجام می‌شود." /></MudTabPanel>
</MudTabs>
}
</DataStateView>

@code{
[Parameter] public Guid Id{get;set;} private bool _loading=true; private string? _error; private InquiryDetailDto? _detail; private SupplierLookupDto? _supplier; private InquiryComparisonDto? _comparison;
protected override Task OnInitializedAsync()=>Load();
private async Task Load(){_loading=true;_error=null;try{_detail=await Api.GetInquiryAsync(Id);}catch(Exception ex){_error=ex.Message;}finally{_loading=false;}}
private RenderFragment Info(string l,string v)=>@<div class="summary-item"><span>@l</span><strong>@v</strong></div>;
private async Task Send(){try{await Api.SendInquiryAsync(Id);Snackbar.Add("استعلام ارسال شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private async Task AddSupplier(SupplierLookupDto? s){if(s is null)return;try{await Api.AddInquirySupplierAsync(Id,new(s.Id));Snackbar.Add("تأمین‌کننده اضافه شد.",Severity.Success);_supplier=null;await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private async Task AddQuote(){var target=_detail?.Suppliers.FirstOrDefault();if(target is null){Snackbar.Add("ابتدا تأمین‌کننده اضافه کنید.",Severity.Warning);return;}try{await Api.AddSupplierQuoteAsync(Id,new(target.Id,"Q-"+DateTime.Now.Ticks,null,null,"IRR",null,null,null,1000,0,0,null,null));Snackbar.Add("پیشنهاد ثبت شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private async Task SelectQuote(Guid q){try{await Api.SelectSupplierQuoteAsync(Id,q,"انتخاب از رابط کاربری");Snackbar.Add("پیشنهاد انتخاب شد.",Severity.Success);await Load();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
private async Task LoadComparison(){try{_comparison=await Api.GetInquiryComparisonAsync(Id);}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
}
