@page "/purchase/inquiries"
@inject IPetroProcureApiClient Api
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>استعلام‌ها</PageTitle>
<PageHeader Title="استعلام‌ها" Subtitle="مدیریت RFQ / استعلام قیمت و فنی تأمین‌کنندگان">
    <PermissionView Permission="@InquiryUiPolicy.Create">
        <MudButton Href="/purchase/inquiries/create" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">ایجاد استعلام</MudButton>
    </PermissionView>
</PageHeader>

<MudPaper Class="filter-panel" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="3"><MudTextField @bind-Value="_search" Label="جستجو" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2"><MudSelect T="InquiryStatus?" @bind-Value="_status" Label="وضعیت" Variant="Variant.Outlined" Clearable="true">@foreach(var s in Enum.GetValues<InquiryStatus>()){<MudSelectItem T="InquiryStatus?" Value="@s">@InquiryUiPolicy.StatusText(s)</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="2"><MudSelect T="InquiryType?" @bind-Value="_type" Label="نوع" Variant="Variant.Outlined" Clearable="true">@foreach(var t in Enum.GetValues<InquiryType>()){<MudSelectItem T="InquiryType?" Value="@t">@InquiryUiPolicy.TypeText(t)</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="3"><MudTextField @bind-Value="_fileNumber" Label="شماره پرونده خرید" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center"><MudButton Variant="Variant.Outlined" OnClick="Reload">اعمال</MudButton></MudItem>
    </MudGrid>
</MudPaper>

<MudTable ServerData="LoadServerData" @ref="_table" Dense="true" Hover="true" Elevation="0" Class="data-panel">
    <HeaderContent><MudTh>شماره</MudTh><MudTh>پرونده خرید</MudTh><MudTh>عنوان</MudTh><MudTh>وضعیت</MudTh><MudTh>نوع</MudTh><MudTh>اقلام</MudTh><MudTh>تأمین‌کنندگان</MudTh><MudTh>مهلت</MudTh><MudTh>ایجاد</MudTh><MudTh>عملیات</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.InquiryNumber</MudTd><MudTd>@(context.PurchaseFileNumber??"—")</MudTd><MudTd>@context.Title</MudTd>
        <MudTd><StatusChip Text="@InquiryUiPolicy.StatusText(context.Status)" /></MudTd><MudTd>@InquiryUiPolicy.TypeText(context.InquiryType)</MudTd>
        <MudTd>@context.ItemCount</MudTd><MudTd>@context.SupplierCount</MudTd><MudTd><DateDisplay Value="@context.DeadlineDate" /></MudTd><MudTd><DateDisplay Value="@context.CreatedAt" /></MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Visibility" OnClick="@(()=>Navigation.NavigateTo($"/purchase/inquiries/{context.Id}"))" />
            <PermissionView Permission="@InquiryUiPolicy.Send"><MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="@(()=>Send(context.Id))" /></PermissionView>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><EmptyState Title="استعلامی یافت نشد" Description="برای پرونده‌های خرید می‌توانید استعلام جدید ایجاد کنید." /></NoRecordsContent>
</MudTable>

@code {
    private MudTable<InquirySummaryDto>? _table; private string? _search,_fileNumber; private InquiryStatus? _status; private InquiryType? _type;
    private Task Reload()=>_table?.ReloadServerData()??Task.CompletedTask;
    private async Task<TableData<InquirySummaryDto>> LoadServerData(TableState state,CancellationToken ct){var r=await Api.GetInquiriesAsync(new(_search,null,_fileNumber,_status,_type,null,null,null,null,null,state.SortLabel??"CreatedAt",state.SortDirection!=SortDirection.Ascending,state.Page+1,state.PageSize),ct);return new(){Items=r.Items,TotalItems=(int)r.TotalCount};}
    private async Task Send(Guid id){try{await Api.SendInquiryAsync(id);Snackbar.Add("استعلام ارسال شد.",Severity.Success);await Reload();}catch(Exception ex){Snackbar.Add(ex.Message,Severity.Error);}}
}
