@page "/purchase/inquiries/create"
@inject IPetroProcureApiClient Api
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>ایجاد استعلام</PageTitle>
<PageHeader Title="ایجاد استعلام" Subtitle="ثبت استعلام دستی برای یک پرونده خرید" />

<DataStateView TItem="PurchaseFileSummaryDto" Loading="_loadingFiles" Error="_loadError" Items="_purchaseFiles" Retry="LoadPurchaseFiles">
    <MudForm @ref="_form">
    <MudPaper Class="form-panel" Elevation="0">
        <MudGrid>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_title" Label="عنوان" Required="true" RequiredError="عنوان الزامی است" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudSelect T="InquiryType" @bind-Value="_type" Label="نوع" Variant="Variant.Outlined">@foreach(var t in Enum.GetValues<InquiryType>()){<MudSelectItem Value="@t">@InquiryUiPolicy.TypeText(t)</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudDatePicker @bind-Date="_deadline" Label="مهلت پاسخ" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_description" Label="توضیحات" Lines="3" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12">
                <MudSelect T="Guid?" @bind-Value="_purchaseFileId" Label="پرونده خرید" Required="true" RequiredError="پرونده خرید الزامی است" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var file in _purchaseFiles)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)file.Id)">@file.FileNumber — @file.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>
    <div class="form-actions"><MudButton Disabled="_saving" Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">ذخیره</MudButton><MudButton Href="/purchase/inquiries">بازگشت</MudButton></div>
    </MudForm>
</DataStateView>

@code {
    private MudForm? _form; private bool _saving,_loadingFiles=true; private string _title="",_description=""; private string? _loadError; private Guid? _purchaseFileId; private InquiryType _type=InquiryType.PriceInquiry; private DateTime? _deadline; private List<PurchaseFileSummaryDto> _purchaseFiles=[];
    protected override Task OnInitializedAsync()=>LoadPurchaseFiles();
    private async Task LoadPurchaseFiles(){_loadingFiles=true;_loadError=null;try{var result=await Api.GetPurchaseFilesAsync(new PurchaseFileListRequest(PageSize:50));_purchaseFiles=result.Items.ToList();}catch(Exception ex){_loadError=UiErrorText.From(ex);}finally{_loadingFiles=false;}}
    private async Task Save(){await _form!.Validate();if(!_form.IsValid||_saving)return;if(_purchaseFileId is null){Snackbar.Add("انتخاب پرونده خرید الزامی است.",Severity.Warning);return;}_saving=true;try{var result=await Api.CreateInquiryAsync(new(_purchaseFileId.Value,_title,_type,_deadline,_description));Snackbar.Add("استعلام ایجاد شد.",Severity.Success);Navigation.NavigateTo($"/purchase/inquiries/{result.Inquiry.Id}");}catch(Exception ex){Snackbar.Add("ایجاد استعلام ناموفق بود. "+UiErrorText.From(ex),Severity.Error);}finally{_saving=false;}}
}
