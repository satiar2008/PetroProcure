@inject IPetroProcureApiClient Api

<MudPaper Class="pa-3" Elevation="0">
    <MudTextField @bind-Value="_term" Label="@Label" Placeholder="شماره یا متن ماده را جستجو کنید"
                  Disabled="Disabled" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
    <MudButton Class="mt-2" Variant="Variant.Outlined" Disabled="Disabled || _loading" OnClick="SearchAsync">جستجو</MudButton>

    @if (SelectedArticle is not null)
    {
        <MudAlert Severity="Severity.Info" Class="mt-3">
            <strong>@SelectedArticle.ArticleNumber</strong> — @SelectedArticle.Title
        </MudAlert>
    }

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mt-3" />
    }
    else if (_searched && _items.Count == 0)
    {
        <EmptyState Title="ماده‌ای یافت نشد" Description="عبارت جستجو را تغییر دهید یا ابتدا ماده قانونی ثبت کنید." />
    }
    else if (_items.Count > 0)
    {
        <MudTable Items="_items" Dense="true" Hover="true" Class="mt-3">
            <HeaderContent><MudTh>شماره</MudTh><MudTh>عنوان</MudTh><MudTh></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.ArticleNumber</MudTd>
                <MudTd>@context.Title</MudTd>
                <MudTd><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SelectAsync(context))">انتخاب</MudButton></MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter] public string Label { get; set; } = "انتخاب ماده قانونی";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public Guid? DocumentId { get; set; }
    [Parameter] public LegalArticleDto? SelectedArticle { get; set; }
    [Parameter] public EventCallback<LegalArticleDto?> SelectedArticleChanged { get; set; }

    private string? _term;
    private bool _loading;
    private bool _searched;
    private readonly List<LegalArticleDto> _items = [];

    private async Task SearchAsync()
    {
        _loading = true; _searched = true;
        try
        {
            var result = await Api.SearchLegalArticlesAsync(new LegalArticleSearchRequest(_term, DocumentId, PageSize: 20));
            _items.Clear();
            _items.AddRange(result.Items);
        }
        finally { _loading = false; }
    }

    private async Task SelectAsync(LegalArticleDto item)
    {
        SelectedArticle = item;
        await SelectedArticleChanged.InvokeAsync(item);
    }
}
